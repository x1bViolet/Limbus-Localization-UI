<Abstractions:FadeableWindow
	x:Class="LCLocalizationInterface.MainWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:Abstractions="clr-namespace:LCLocalizationInterface.Internal.Abstractions"
	xmlns:AvalonEditRendering="clr-namespace:ICSharpCode.AvalonEdit.Rendering;assembly=ICSharpCode.AvalonEdit"
	xmlns:Blend="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:Entanglement="clr-namespace:LCLocalizationInterface.Entanglement"
	xmlns:InternalStyle="clr-namespace:LCLocalizationInterface.Internal.UIStyle"
	xmlns:JsonManaging="clr-namespace:LCLocalizationInterface.LimbusRegistry.ManualJsonFilesManaging"
	xmlns:Limbus="clr-namespace:LCLocalizationInterface.LimbusRegistry"
	xmlns:LimbusIValueConverters="clr-namespace:LCLocalizationInterface.LimbusRegistry.LimbusIValueConverters"
	xmlns:MarkupCompatibility="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:T="clr-namespace:LCLocalizationInterface.MarkupExtensions"
	xmlns:Terminus="clr-namespace:LCLocalizationInterface.Internal.Terminus"
	xmlns:sys="clr-namespace:System;assembly=mscorlib"
	Title="{Binding ElementName=CaptionBinder, Path=Text}"
	Width="{DynamicResource DM:Width}"
	Height="{DynamicResource DM:Height}"
	MinWidth="{DynamicResource DM:MinWidth}"
	MinHeight="{DynamicResource DM:MinHeight}"
	MaxWidth="{DynamicResource DM:MaxWidth}"
	Blend:DataContext="{Blend:DesignInstance Type=Entanglement:EntanglementModel}"
	MarkupCompatibility:Ignorable="Blend"
	DataContext="{Binding Source={StaticResource ThatOnePeskyMvvmThing}}"
	PreviewKeyDown="MainWindow_PreviewKeyDown"
	PreviewKeyUp="MainWindow_PreviewKeyUp"
	PreviewMouseDown="MainWindow_PreviewMouseDown"
	ResizeMode="CanResizeWithGrip"
	SizeChanged="SizeChanged_CheckThemeBackgroundImageVisibility"
	Style="{StaticResource Base:WindowLayout}"
	Topmost="True"
	WindowStartupLocation="CenterScreen">

	<WindowChrome.WindowChrome>
		<WindowChrome x:Name="CurrentWindowChrome" CaptionHeight="0" ResizeBorderThickness="10" />
	</WindowChrome.WindowChrome>

	<Abstractions:FadeableWindow.Resources>
		<ResourceDictionary>
			<ScaleTransform x:Key="XReversed" ScaleX="-1" />

			<!--    This is a @EditorModesShelf.MainWindowDimensing values, changed by EditorModeAbstraction<LocalizationDataType>.SwitchUI()    -->
			<!--    Acts as a single control panel so i don't have to search for these values ​​among the UI elements    -->

			<sys:Double x:Key="DM:MaxWidth">1000</sys:Double>
			<sys:Double x:Key="DM:MinWidth">713</sys:Double>
			<sys:Double x:Key="DM:MinHeight">425</sys:Double>

			<sys:Double x:Key="DM:Width">1000</sys:Double>
			<sys:Double x:Key="DM:Height">600</sys:Double>

			<GridLength x:Key="DM:RichTextViewsHeight">387</GridLength>
			<GridLength x:Key="DM:TextEditorAndRichTextViewsWidth">706</GridLength>

			<sys:Int32 x:Key="DM:RichTextViewsTabIndex">0</sys:Int32>
			<sys:Int32 x:Key="DM:RightMenuSectionsTabIndex">0</sys:Int32>

		</ResourceDictionary>
	</Abstractions:FadeableWindow.Resources>

	<InternalStyle:InstancedWindowLayout x:Name="VisualBorder" BorderBrush="{DynamicResource Theme:Common.MainWindow.Border.Color}" CornerRadius="{DynamicResource Theme:Common.MainWindow.Border.CornerRadius}" WindowDragging="MainWindowOverrideDragMove">

		<InternalStyle:InstancedWindowLayout.Title>
			<Terminus:IntenseStareType1 Style="{StaticResource Base:WindowLayout.TitleBar.TitleText}" UID="[Main UI] * Program Title" />
		</InternalStyle:InstancedWindowLayout.Title>

		<InternalStyle:InstancedWindowLayout.Navigation>
			<StackPanel MouseEnter="DisableWindowChromeResizeBorder" MouseLeave="EnableWindowChromeResizeBorder" Orientation="Horizontal">
				<Canvas Margin="0 0 -5 0" IsHitTestVisible="False">
					<Grid Canvas.Right="0" Width="15" Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorLevel=1, AncestorType=StackPanel}}" Background="{DynamicResource Theme:TitleBar.Background.Color}">
						<Grid.OpacityMask>
							<LinearGradientBrush StartPoint="0 0" EndPoint="1 0">
								<GradientStop Color="#00000000" />
								<GradientStop Offset="0.5" Color="#000000" />
							</LinearGradientBrush>
						</Grid.OpacityMask>
					</Grid>
				</Canvas>
				<Button Click="Minimize" Style="{StaticResource Base:TitleBar.Button.Defaults.Minimize}" />
				<Button T:BooleanStateHandler.IsVisible="{Binding DataContextDomain.Configuration.Internal.SpecificTitleBarButtonsOnOff.EditorModeSwitch, FallbackValue=True}" Click="ModeSwitchContextMenu_OpenOnLeftClick" Content="">
					<Button.ContextMenu>
						<ContextMenu>
							<ContextMenu.Resources>
								<Style BasedOn="{StaticResource {x:Type Terminus:MenuItem_T1}}" TargetType="{x:Type Terminus:MenuItem_T1}">
									<EventSetter Event="Click" Handler="ModeSwitchContextMenu_Click" />
								</Style>
							</ContextMenu.Resources>
							<Terminus:MenuItem_T1 IsHitTestVisible="False" RichText="Opened files" TextBlock.TextAlignment="Center" UID="[Main UI] * Current editor switch — Title" />
							<Separator />
							<Terminus:MenuItem_T1 x:Name="ModeSwitchButton_MainMenu" RichText="Main menu" UID="[Main UI] * Current editor switch — Main menu" />
							<Separator />
							<Terminus:MenuItem_T1 x:Name="ModeSwitchButton_Skills" RichText="Skills" UID="[Main UI] * Current editor switch — Skills" />
							<Terminus:MenuItem_T1 x:Name="ModeSwitchButton_Passives" RichText="Passives" UID="[Main UI] * Current editor switch — Passives" />
							<Terminus:MenuItem_T1 x:Name="ModeSwitchButton_Keywords" RichText="Keywords" UID="[Main UI] * Current editor switch — Keywords" />
							<Terminus:MenuItem_T1 x:Name="ModeSwitchButton_EGOGifts" RichText="E.G.O Gifts" UID="[Main UI] * Current editor switch — E.G.O Gifts" />
							<Terminus:MenuItem_T1 x:Name="ModeSwitchButton_ObservationLogs" RichText="Observation Logs" UID="[Main UI] * Current editor switch — Observation Logs" />
							<Separator />
							<Terminus:MenuItem_T1 x:Name="ModeSwitchButton_DiscardCurrentFile" RichText="Discard current file" UID="[Main UI] * Current editor switch — Discard current file" />
						</ContextMenu>
					</Button.ContextMenu>
				</Button>
				<Button T:BooleanStateHandler.IsVisible="{Binding DataContextDomain.Configuration.Internal.SpecificTitleBarButtonsOnOff.OpenSkillsDisplayInfoManager, FallbackValue=True}" Click="ShowSkillDisplayInfoManagerWindow" Content="">
					<Button.ToolTip>
						<ToolTip MaxWidth="700" Style="{StaticResource Theme:ControlStyles.Tooltip}">
							<Terminus:IntenseStareType1 FontSize="15" Foreground="{DynamicResource Theme:UIText.MainWindow.Foreground.Tooltips}" LineHeight="18" RichText="Open Skills Display Info manager" UID="[Skills DI Manager] * Title bar button tooltip" />
						</ToolTip>
					</Button.ToolTip>
				</Button>
				<Button T:BooleanStateHandler.IsVisible="{Binding DataContextDomain.Configuration.Internal.SpecificTitleBarButtonsOnOff.SwitchUIToPreviewCreator, FallbackValue=True}" Click="PreviewCreatorUISwitchButton_Click" Content="">
					<Button.ToolTip>
						<ToolTip MaxWidth="700" Style="{StaticResource Theme:ControlStyles.Tooltip}">
							<Terminus:IntenseStareType1 FontSize="15" Foreground="{DynamicResource Theme:UIText.MainWindow.Foreground.Tooltips}" LineHeight="18" RichText="Switch UI to Identity/E.G.O Preview creator" UID="[C] * Title bar button tooltip" />
						</ToolTip>
					</Button.ToolTip>
				</Button>
				<Button T:BooleanStateHandler.IsVisible="{Binding DataContextDomain.Configuration.Internal.SpecificTitleBarButtonsOnOff.ExportTextToImage, FallbackValue=True}" Click="MakeLimbusTextPreviewScanButton_Click" Content="" ToolTipOpening="MakeLimbusTextPreviewScanButton_ToolTipOpening">
					<Button.ToolTip>
						<ToolTip MaxWidth="700" Style="{StaticResource Theme:ControlStyles.Tooltip}">
							<Terminus:IntenseStareType1 FontSize="15" Foreground="{DynamicResource Theme:UIText.MainWindow.Foreground.Tooltips}" LineHeight="18" RichText="Export preview to PNG (To [⇲] Assets Directory\Scans directory)" UID="[Main UI] * Export Preview as PNG Tooltip" />
						</ToolTip>
					</Button.ToolTip>
				</Button>
				<Button Click="ShowSettings" Content="" Visibility="Visible" />
				<Button Click="FadeClose" Style="{StaticResource Base:TitleBar.Button.Defaults.Close}" />
			</StackPanel>
		</InternalStyle:InstancedWindowLayout.Navigation>

		<InternalStyle:InstancedWindowLayout.Content>
			<Grid>
				<Terminus:IntenseStareType1 x:Name="CaptionBinder" UID="[Main UI] [!] [#] * Program Title (Window Caption)" Visibility="Collapsed" />

				<InternalStyle:SingleViewer x:Name="WindowContentView" SelectedIndex="0">

					<Grid x:Uid="LOCALIZATION EDITOR" Background="{DynamicResource Theme:Common.MainWindow.Background.Color}">

						<Grid Margin="0 1 0 0">

							<Grid x:Name="UnsavedChangesGrid" Panel.ZIndex="1" Background="{DynamicResource Theme:UnsavedChanges.MainEditor.BlurredBackground}" Visibility="Collapsed">
								<Grid x:Uid="Click area to cancel" Background="Transparent" MouseLeftButtonUp="UnsavedChangesDialog_ButtonsClick_Cancel" />
								<Border Width="500" Height="380" Style="{StaticResource Theme:ControlStyles.OtherBorderLikeThing}">
									<Grid Margin="10">
										<Terminus:IntenseStareType1 FontSize="40" RichText="Unsaved changes" TextAlignment="Center" UID="[Unsaved Changes] * Title" />
										<InternalStyle:SurfaceScrollViewer Height="240" Margin="10 55 10 0" VerticalAlignment="Top" VerticalScrollBarVisibility="Hidden">
											<Terminus:IntenseStareType1 FontSize="21" UID="[Unsaved Changes] [-] * Information Text" />
										</InternalStyle:SurfaceScrollViewer>
										<StackPanel HorizontalAlignment="Center" VerticalAlignment="Bottom" Orientation="Horizontal">
											<Button Height="45" Margin="0 0 5 0" Click="UnsavedChangesDialog_ButtonsClick_Proceed" Style="{StaticResource Theme:ControlStyles.ElongatedButton}">
												<Terminus:IntenseStareType1 Width="150" FontSize="30" RichText="Proceed" TextAlignment="Center" UID="[Unsaved Changes] * Proceed" />
											</Button>
											<Button Height="45" Click="UnsavedChangesDialog_ButtonsClick_Cancel" Style="{StaticResource Theme:ControlStyles.ElongatedButton}">
												<Terminus:IntenseStareType1 Width="150" FontSize="30" RichText="Cancel" TextAlignment="Center" UID="[Unsaved Changes] * Cancel" />
											</Button>
										</StackPanel>
									</Grid>
								</Border>
							</Grid>

							<!--    ClipToBounds="True" to prevent blur effect spreading on title bar when unsaved changes is shown    -->
							<Grid x:Name="LocalizationEditorGrid" ClipToBounds="True">

								<!--#region Background image-->
								<StackPanel x:Name="BackgroundImageStackPanel" VerticalAlignment="Top">
									<Image HorizontalAlignment="Left" Source="{DynamicResource Theme:Common.MainWindow.Background.Image}" Stretch="None" />

									<!--    Mirrored version at the bottom    -->
									<Image Margin="0 -1 0 0" HorizontalAlignment="Left" RenderTransformOrigin="0 0.5" Source="{DynamicResource Theme:Common.MainWindow.Background.Image}" Stretch="None">
										<Image.RenderTransform>
											<ScaleTransform ScaleY="-1" />
										</Image.RenderTransform>
									</Image>
								</StackPanel>

								<Border Background="{DynamicResource Theme:Common.MainWindow.Background.Image.Shadow}" />
								<!--#endregion-->

								<Grid x:Name="JsonTextEditorAndRichTextViews" Uid="Json editor, Text preview, Right menu" Grid.Column="0" Margin="2">
									<Grid.ColumnDefinitions>

										<!--    Space left for Rich Text Views    -->
										<ColumnDefinition x:Name="TextEditorAndRichTextViewsWidth" Width="{DynamicResource DM:TextEditorAndRichTextViewsWidth}" />

										<!--    Only TextEditorAndRichTextViewsWidth should change, and this one should remain at "1*" due to the need for auto-sizing of the Right Menu borders    -->
										<ColumnDefinition Width="1*" />

									</Grid.ColumnDefinitions>

									<Grid x:Name="JsonTextEditor_And_RichTextViews" x:Uid="Json editor, Text preview" Grid.Row="0">
										<Grid.RowDefinitions>
											<RowDefinition />
											<RowDefinition x:Name="RichTextViews__PARENT_Height" Height="{DynamicResource DM:RichTextViewsHeight}" />
										</Grid.RowDefinitions>


										<Grid.Resources>

											<ContextMenu x:Key="LimbusJsonTextEditor_Conversions">
												<ContextMenu.Resources>
													<Style BasedOn="{StaticResource {x:Type Terminus:IntenseStareType1}}" TargetType="{x:Type Terminus:IntenseStareType1}">
														<Setter Property="FontSize" Value="13.5" />
													</Style>
													<Style BasedOn="{StaticResource {x:Type Terminus:MenuItem_T1}}" TargetType="{x:Type Terminus:MenuItem_T1}">
														<EventSetter Event="Click" Handler="TextEditor_ContextMenuClick" />
														<Setter Property="Padding" Value="5 2.5 5 2.5" />
													</Style>
												</ContextMenu.Resources>
												<Terminus:MenuItem_T1 x:Uid="Insert Style" RichText="Insert &lt;style&gt;" UID="[Context Menu] * Insert Style" />
												<Separator />
												<Terminus:MenuItem_T1 x:Uid="&lt;TMPro&gt; To [KeywordID]" RichText="TextMeshPro to [KeywordID]" UID="[Context Menu] * TextMeshPro to [KeywordID]" />
												<Terminus:MenuItem_T1 x:Uid="&lt;TMPro&gt; To Shorthands" RichText="TextMeshPro to Shorthands" UID="[Context Menu] * TextMeshPro to Shorthands" />
												<Terminus:MenuItem_T1 x:Uid="Implicit To [KeywordID]" RichText="Implicit to [KeywordID]" UID="[Context Menu] * Implicit to [KeywordID]" />
												<Terminus:MenuItem_T1 x:Uid="Implicit To Shorthands" RichText="Implicit to Shorthands" UID="[Context Menu] * Implicit to Shorthands" />
												<Terminus:MenuItem_T1 x:Uid="[KeywordID] To Shorthands" RichText="[KeywordID] to Shorthand" UID="[Context Menu] * [KeywordID] to Shorthands" />
												<Terminus:MenuItem_T1 x:Uid="[KeywordID] To &lt;TMPro&gt;" RichText="[KeywordID] to TextMeshPro" UID="[Context Menu] * [KeywordID] to TextMeshPro" />
											</ContextMenu>

											<ContextMenu x:Key="LimbusJsonTextEditor_ExtraReplacements" />

										</Grid.Resources>


										<Terminus:IntenseStareType1 x:Name="LimbusJsonTextEditor_ExtraReplacementsContextMenu_ItemHeaderBinding" FontSize="13.5" UID="[Context Menu] [-] * Extra replacements item header" Visibility="Collapsed" />

										<!--    It is.    -->
										<Limbus:JsonTextEditor x:Name="LimbusJsonTextEditor" Grid.Row="0" ContextMenu="{StaticResource LimbusJsonTextEditor_Conversions}" ContextMenuOpening="LimbusJsonTextEditor_ContextMenuOpening" TextChanged="TextEditor_TextChanged" />

										<ScrollViewer x:Name="WindowFocusManagingPlaceholder" Grid.Row="1" IsHitTestVisible="False" Opacity="0" Visibility="Visible" />





										<!--    All text preview layouts is there    -->
										<InternalStyle:SingleViewer x:Name="RichTextViews" Grid.Row="1" SelectedIndex="{DynamicResource DM:RichTextViewsTabIndex}">

											<InternalStyle:SingleViewer.Resources>
												<LimbusIValueConverters:EscapedLineBreaksConverter x:Key="EscapedLineBreaksConverter" />
											</InternalStyle:SingleViewer.Resources>

											<Grid x:Uid="[0] — Main menu text">
												<!--    RenderOptions.BitmapScalingMode="NearestNeighbor" makes this image clearer    -->
												<Image
													Width="706"
													Margin="1 0 0 0"
													HorizontalAlignment="Left"
													VerticalAlignment="Bottom"
													RenderOptions.BitmapScalingMode="NearestNeighbor"
													Source="/UI/Limbus/Skills/Background.png" />
												<InternalStyle:SurfaceScrollViewer x:Name="RichTextViews__MainMenu_COMPOSITION_SurfaceScrollViewer" Margin="10 20 40 50">
													<Limbus:TMProEmitter
														x:Name="RichTextViews__MainMenu_DefaultDesc"
														Margin="5 0 0 0"
														Limbus:FontType="Context"
														Limbus:RichText="{Binding DataContextDomain.Editor.MainMenuDocument.Text}"
														Limbus:TextProcessingMode="EGOGifts"
														FontSize="20" />
												</InternalStyle:SurfaceScrollViewer>
											</Grid>





											<Grid x:Uid="[1] — Skills">

												<Image
													Width="706"
													Margin="1 0 0 0"
													HorizontalAlignment="Left"
													VerticalAlignment="Bottom"
													RenderOptions.BitmapScalingMode="NearestNeighbor"
													Source="/UI/Limbus/Skills/Background.png" />

												<InternalStyle:SurfaceScrollViewer x:Name="RichTextViews__Skills_COMPOSITION_SurfaceScrollViewer" Margin="10 20 33 50">
													<StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Background="Transparent">

														<StackPanel.Style>
															<Style TargetType="StackPanel">

																<Setter Property="Width" Value="663" />

																<Style.Triggers>
																	<!--    Reduce descs Width when RichTextViews__Skills_COMPOSITION_EGOResourcesDecoration is set to be visible (E.G.O Skills)    -->
																	<DataTrigger Binding="{Binding ElementName=RichTextViews__Skills_COMPOSITION_EGOResourcesDecoration, Path=Visibility}" Value="Visible">
																		<Setter Property="Width" Value="573" />
																	</DataTrigger>
																</Style.Triggers>

															</Style>
														</StackPanel.Style>

														<Limbus:SkillNameReplicaUIElement
															x:Name="RichTextViews__Skills_COMPOSITION_SkillNameReplica"
															Margin="0 -20 0 8"
															HorizontalAlignment="Left"
															Affinity="None"
															DamageType="Blunt"
															Rank="3"
															SkillName="{Binding DataContextDomain.Editor.CurrentUptie.KeylessDedicatedDocument_MainName.Text, Converter={StaticResource EscapedLineBreaksConverter}}"
															SkillType="Evade">
															<Limbus:SkillNameReplicaUIElement.Style>
																<Style BasedOn="{StaticResource {x:Type Limbus:SkillNameReplicaUIElement}}" TargetType="{x:Type Limbus:SkillNameReplicaUIElement}">
																	<!--    Default mode    -->
																	<Setter Property="NameMaximumWidth" Value="485" />
																	<Style.Triggers>
																		<!--    Reduce NameMaximumWidth when RichTextViews__Skills_COMPOSITION_EGOResourcesDecoration is set to be visible (E.G.O Skills)    -->
																		<DataTrigger Binding="{Binding ElementName=RichTextViews__Skills_COMPOSITION_EGOResourcesDecoration, Path=Visibility}" Value="Visible">
																			<Setter Property="NameMaximumWidth" Value="385" />
																		</DataTrigger>
																		<DataTrigger Binding="{Binding DataContextDomain.Configuration.PreviewSettings.Base.EnableSkillNamesReplication}" Value="False">
																			<Setter Property="Height" Value="0" />
																		</DataTrigger>
																	</Style.Triggers>
																</Style>
															</Limbus:SkillNameReplicaUIElement.Style>
														</Limbus:SkillNameReplicaUIElement>






														<Limbus:TMProEmitter
															x:Name="RichTextViews__Skills_MainDescription"
															Margin="5 0 7 0"
															Limbus:FontType="Context"
															Limbus:RichText="{Binding DataContextDomain.Editor.CurrentUptie.DedicatedDocument_MainDescription.Text}"
															Limbus:TextProcessingMode="Skills"
															Background="Transparent"
															FontSize="20"
															LineHeight="27"
															PreviewMouseRightButtonDown="RichTextViews__Skills_FastSwitch_ToSkillMainDescription" />


														<!--    Coins    -->
														<VirtualizingStackPanel x:Name="RichTextViews__Skills_COMPOSITION_Coins" Margin="5 0 40.2 0">

															<!--    Coins and their descriptions are added by the MainWindow.Skills_SetupCoinsView() when window is loaded (Their count and total size with all descs are too huge)    -->

														</VirtualizingStackPanel>


														<Limbus:TMProEmitter
															x:Name="RichTextViews__Skills_FlavorDescription"
															Margin="5 25 0 0"
															Limbus:FontType="Context"
															Limbus:RichText="{Binding DataContextDomain.Editor.CurrentUptie.DedicatedDocument_FlavorDescription.Text, FallbackValue={x:Null}}"
															Limbus:TextProcessingMode="None"
															Background="Transparent"
															FontSize="17.5"
															FontStyle="Italic"
															Foreground="#8a592f"
															LineHeight="25"
															PreviewMouseRightButtonDown="RichTextViews__Skills_FastSwitch_ToSkillFlavorDescription" />




													</StackPanel>
												</InternalStyle:SurfaceScrollViewer>


												<Grid x:Name="RichTextViews__Skills_COMPOSITION_EGOResourcesDecoration" HorizontalAlignment="Right" T:NullStateHandler.IsVisible="{T:NullStateBinding DataContextDomain.Editor.CurrentUptie.KeylessDedicatedDocument_EGOAbnormalityName}">

													<Grid.Resources>
														<Style TargetType="{x:Type Image}">
															<Setter Property="Width" Value="40" />
															<Setter Property="Opacity" Value="0.8" />
														</Style>
														<Style TargetType="{x:Type StackPanel}">
															<Setter Property="HorizontalAlignment" Value="Right" />
														</Style>
														<Style TargetType="{x:Type TextBlock}">
															<Setter Property="FontFamily" Value="/UI/Fonts/#EXCELSIOR SANS" />
															<Setter Property="Foreground" Value="#EBCAA2" />
															<Setter Property="TextAlignment" Value="Right" />
															<Setter Property="Margin" Value="0 10.5 0 0" />
															<Setter Property="Opacity" Value="0.5" />
															<Setter Property="FontSize" Value="28" />
															<Setter Property="Text" Value="0" />
															<Setter Property="Effect">
																<Setter.Value>
																	<DropShadowEffect BlurRadius="4" ShadowDepth="0" />
																</Setter.Value>
															</Setter>
														</Style>
													</Grid.Resources>
													<StackPanel Margin="0 9 56 0">
														<Image Margin="0 2 0 0" Opacity="1" Source="/UI/Limbus/Skills/Affinity Icons/Wrath.png" />
														<Image Margin="0 4 0 0" Source="/UI/Limbus/Skills/Affinity Icons/Lust.png" />
														<Image Margin="0 4 0 0" Source="/UI/Limbus/Skills/Affinity Icons/Sloth.png" />
														<Image Margin="-5 5 0 0" Source="/UI/Limbus/Skills/Affinity Icons/Gluttony.png" />
														<Image Margin="0 4 0 0" Opacity="1" Source="/UI/Limbus/Skills/Affinity Icons/Gloom.png" />
														<Image Margin="0 4 0 0" Opacity="1" Source="/UI/Limbus/Skills/Affinity Icons/Pride.png" />
														<Image Margin="0 4 -2 0" Source="/UI/Limbus/Skills/Affinity Icons/Envy.png" />
													</StackPanel>
													<StackPanel Margin="0 24 47 0">
														<TextBlock Opacity="1" Text="2" />
														<TextBlock />
														<TextBlock />
														<TextBlock />
														<TextBlock Opacity="1" Text="1" />
														<TextBlock Opacity="1" Text="6" />
														<TextBlock />
													</StackPanel>
													<Border Width="1" Margin="0 30 105.5 81" HorizontalAlignment="Right" Opacity="0.4" Visibility="Visible">
														<Border.Background>
															<LinearGradientBrush StartPoint="0 0" EndPoint="0 1">
																<GradientStop Offset="0" Color="#00000000" />
																<GradientStop Offset="0.1" Color="#EBCAA2" />
																<GradientStop Offset="0.5" Color="#EBCAA2" />
																<GradientStop Offset="0.9" Color="#EBCAA2" />
																<GradientStop Offset="1" Color="#00000000" />
															</LinearGradientBrush>
														</Border.Background>
													</Border>
												</Grid>

											</Grid>





											<Grid x:Uid="[2] — Passives">

												<!--    RenderOptions.BitmapScalingMode="NearestNeighbor" makes this image clearer    -->
												<Image
													Width="706"
													Margin="1 0 0 0"
													HorizontalAlignment="Left"
													VerticalAlignment="Bottom"
													RenderOptions.BitmapScalingMode="NearestNeighbor"
													Source="/UI/Limbus/Skills/Background.png" />

												<InternalStyle:SurfaceScrollViewer x:Name="RichTextViews__Passives_COMPOSITION_SurfaceScrollViewer" Margin="10 20 40 50">
													<StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Cursor="">
														<Limbus:NameLineElement
															x:Name="RichTextViews__Passives_Name"
															Margin="5 0 0 8"
															HorizontalAlignment="Left"
															DisplayedName="{Binding DataContextDomain.Editor.CurrentPassive.KeylessDedicatedDocument_Name.Text, Converter={StaticResource EscapedLineBreaksConverter}}"
															DropShadowEffect_Depth="0"
															FillColorRightOffsetReduction="12"
															NameMaximumWidth="585" />
														<InternalStyle:SingleViewer x:Name="RichTextViews__Passives_COMPOSITION_MainAndSummaryDescsTab">
															<StackPanel>
																<Limbus:TMProEmitter
																	x:Name="RichTextViews__Passives_MainDescription"
																	Margin="5 0 0 0"
																	Limbus:FontType="Context"
																	Limbus:RichText="{Binding DataContextDomain.Editor.CurrentPassive.DedicatedDocument_MainDescription.Text}"
																	Limbus:TextProcessingMode="Passives"
																	FontSize="20"
																	LineHeight="27"
