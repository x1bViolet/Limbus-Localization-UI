<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:Icons="clr-namespace:VisualStudioControlsTemplates.Icons" xmlns:Terminus="clr-namespace:LCLocalizationInterface.Internal.Terminus">

	<SolidColorBrush x:Key="TextBox.Foreground" Color="#d6d6d6" />

	<SolidColorBrush x:Key="TextBox.Selection.Foreground" Color="#D6D6D6" />
	<SolidColorBrush x:Key="TextBox.Selection.Background" Color="#55D6D6D6" />

	<SolidColorBrush x:Key="TextBox.Static.Border" Color="#424242" />
	<SolidColorBrush x:Key="TextBox.Static.Background" Color="#383838" />

	<SolidColorBrush x:Key="TextBox.MouseOver.Border" Color="#707070" />
	<SolidColorBrush x:Key="TextBox.MouseOver.Background" Color="#383838" />

	<SolidColorBrush x:Key="TextBox.Focus.Border" Color="#999999" />
	<SolidColorBrush x:Key="TextBox.Focus.Background" Color="#1f1f1f" />


	<Style TargetType="{x:Type Terminus:IntenseStareType3}">
		<Setter Property="Background" Value="{DynamicResource TextBox.Static.Background}" />
		<Setter Property="BorderBrush" Value="{DynamicResource TextBox.Static.Border}" />
		<Setter Property="Foreground" Value="{DynamicResource TextBox.Foreground}" />
		<Setter Property="SelectionBackground" Value="{DynamicResource TextBox.Selection.Background}" />
		<Setter Property="SelectionForeground" Value="{DynamicResource TextBox.Selection.Foreground}" />
		<Setter Property="SelectionBorderCornerRadius" Value="0" />
		<Setter Property="CaretBrush" Value="{DynamicResource TextBox.Foreground}" />
		<Setter Property="BorderThickness" Value="1" />
		<Setter Property="KeyboardNavigation.TabNavigation" Value="None" />
		<Setter Property="HorizontalContentAlignment" Value="Left" />
		<Setter Property="FocusVisualStyle" Value="{x:Null}" />
		<Setter Property="AllowDrop" Value="True" />
		<Setter Property="Padding" Value="1 1.2 0 0" />
		<Setter Property="ScrollViewer.PanningMode" Value="VerticalFirst" />
		<Setter Property="Stylus.IsFlicksEnabled" Value="False" />
		<Setter Property="HorizontalScrollBarVisibility" Value="Hidden" />
		<Setter Property="VerticalScrollBarVisibility" Value="Hidden" />
		<Setter Property="ContextMenu">
			<Setter.Value>
				<ContextMenu>
					<ContextMenu.Items>
						<MenuItem Command="ApplicationCommands.Copy" FontSize="16.5">
							<MenuItem.Icon>
								<Icons:Copy />
							</MenuItem.Icon>
							<MenuItem.Header>
								<TextBlock Width="100" Foreground="#d6d6d6" Text="Copy" />
							</MenuItem.Header>
						</MenuItem>
						<MenuItem Command="ApplicationCommands.Cut" FontSize="16.5">
							<MenuItem.Icon>
								<Icons:Cut />
							</MenuItem.Icon>
							<MenuItem.Header>
								<TextBlock Width="100" Foreground="#d6d6d6" Text="Cut" />
							</MenuItem.Header>
						</MenuItem>
						<MenuItem Command="ApplicationCommands.Paste" FontSize="16.5">
							<MenuItem.Icon>
								<Icons:Paste />
							</MenuItem.Icon>
							<MenuItem.Header>
								<TextBlock Width="100" Foreground="#d6d6d6" Text="Paste" />
							</MenuItem.Header>
						</MenuItem>
					</ContextMenu.Items>
				</ContextMenu>
			</Setter.Value>
		</Setter>
		<Style.Triggers>
			<Trigger Property="IsEnabled" Value="false">
				<Setter Property="Background" Value="#333333" />
				<Setter Property="BorderBrush" Value="#3d3d3d" />
			</Trigger>
			<Trigger Property="IsMouseOver" Value="True">
				<Setter Property="BorderBrush" Value="{DynamicResource TextBox.MouseOver.Border}" />
				<Setter Property="Background" Value="{DynamicResource TextBox.MouseOver.Background}" />
			</Trigger>
			<Trigger Property="IsKeyboardFocusWithin" Value="True">
				<Setter Property="BorderBrush" Value="{DynamicResource TextBox.Focus.Border}" />
				<Setter Property="Background" Value="{DynamicResource TextBox.Focus.Background}" />
			</Trigger>
			<Trigger Property="IsEnabled" Value="False">
				<Setter Property="Foreground" Value="#5c5c5c" />
			</Trigger>
		</Style.Triggers>
	</Style>
</ResourceDictionary>