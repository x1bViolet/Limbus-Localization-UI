<ResourceDictionary
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:InternalStyle="clr-namespace:LCLocalizationInterface.Internal.UIStyle"
	xmlns:Limbus="clr-namespace:LCLocalizationInterface.LimbusRegistry"
	xmlns:LimbusIValueConverters="clr-namespace:LCLocalizationInterface.LimbusRegistry.LimbusIValueConverters"
	xmlns:T="clr-namespace:LCLocalizationInterface.MarkupExtensions">
	<Style TargetType="{x:Type Limbus:SkillNameReplicaUIElement}">
		<Setter Property="Affinity" Value="None" />

		<Setter Property="DamageType" Value="None" />
		<Setter Property="SkillType" Value="Attack" />

		<Setter Property="BasePower" Value="?" />
		<Setter Property="CoinPower" Value="+?" />

		<Setter Property="AttackWeight" Value="1" />
		<Setter Property="LevelText" Value="??" />

		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="{x:Type Limbus:SkillNameReplicaUIElement}">

					<ControlTemplate.Resources>
						<LimbusIValueConverters:AffinityAndRankToSkillFrameConverter x:Key="AffinityAndRankToSkillFrameConverter" />
						<LimbusIValueConverters:AttackWeightToCharIconsConverter x:Key="AttackWeightToCharIconsConverter" />
					</ControlTemplate.Resources>

					<Grid Background="Transparent">
						<Grid x:Name="PART_Icon">

							<Grid Width="135" Height="137" HorizontalAlignment="Left" VerticalAlignment="Top">

								<!--    To share color for DropShadowEffects via Bindings as System.Windows.Media.Color instead of SolidColorBrush    -->
								<Border x:Name="AffinityColorCarrier" Background="{TemplateBinding InternalAffinityColor}" Visibility="Collapsed" />




								<!--    Coin Power background pad (Behind the Icon and Affinity frame)    -->
								<Border
									x:Uid="Coin Power background (Slightly rotated)"
									Width="40"
									Height="50"
									Margin="65 24 30 52"
									Background="{TemplateBinding InternalAffinityColor}"
									RenderTransformOrigin="0.5 0.5">
									<Border.RenderTransform>
										<RotateTransform Angle="-11" />
									</Border.RenderTransform>
									<Border.Effect>
										<DropShadowEffect BlurRadius="-1" Direction="-44" ShadowDepth="1.6" />
									</Border.Effect>
								</Border>


								<!--    Same Grid for united DropShadowEffect    -->
								<Grid>
									<!--    Skill Icon    -->
									<Grid
										Width="63.5"
										Height="63.5"
										Margin="53.8 56 0 0"
										HorizontalAlignment="Left"
										VerticalAlignment="Top"
										Background="{TemplateBinding InternalAffinityColor}">
										<Grid>
											<Image x:Uid="Icon image" Source="{TemplateBinding Icon}" />
										</Grid>
										<Grid.OpacityMask>
											<ImageBrush ImageSource="/UI/Limbus/Skills/Icon Opacity Mask.png" />
										</Grid.OpacityMask>
									</Grid>

									<!--    Frame (Affinity)    -->
									<Image
										x:Name="AffinityFrame"
										Width="{Binding Path=Height, RelativeSource={RelativeSource Self}}"
										Height="127"
										Margin="22.8 24 0 0"
										HorizontalAlignment="Left"
										VerticalAlignment="Top"
										Source="{TemplateBinding AffinityAndRank,
										                         Converter={StaticResource AffinityAndRankToSkillFrameConverter}}" />
								</Grid>




								<!--    Base Power and Coin Power    -->
								<TextBlock
									x:Uid="Coin Power"
									Margin="30 24 2 6"
									FontFamily="/UI/Fonts/#EXCELSIOR SANS"
									FontSize="28.6"
									Foreground="#EBCAA2"
									Text="{TemplateBinding CoinPower}"
									TextAlignment="Center">
									<TextBlock.Effect>
										<DropShadowEffect BlurRadius="-1" Direction="-50" ShadowDepth="2" />
									</TextBlock.Effect>
								</TextBlock>
								<TextBlock
									x:Uid="Base Power"
									Margin="0 59 92 0"
									HorizontalAlignment="Right"
									FontFamily="/UI/Fonts/#EXCELSIOR SANS"
									FontSize="50"
									Foreground="#EBCAA2"
									Text="{TemplateBinding BasePower}">
									<TextBlock.Effect>
										<DropShadowEffect BlurRadius="-1" Direction="-50" ShadowDepth="2" />
									</TextBlock.Effect>
								</TextBlock>




								<!--    Damage type    -->
								<Grid
									x:Name="DamageTypeParentGrid"
									Width="26"
									Height="26"
									Margin="70 111 0 0"
									HorizontalAlignment="Left"
									RenderTransformOrigin="0.5 1">
									<Grid.Resources>
										<Style TargetType="{x:Type Border}">
											<Setter Property="OpacityMask">
												<Setter.Value>
													<ImageBrush ImageSource="/UI/Limbus/Skills/Damage Type Opacity Mask.png" />
												</Setter.Value>
											</Setter>
										</Style>
									</Grid.Resources>

									<!--    Frame    -->
									<Border Background="{TemplateBinding InternalAffinityColor}">
										<Border Width="22.3" Height="22.3">
											<Border Background="#7A000000">
												<Border Width="17.3" Height="17.3" Background="#1b1c1b" />
											</Border>
										</Border>
									</Border>

									<!--    Icons    -->
									<InternalStyle:SingleViewer x:Name="DamageTypesSingleViewer" Width="25" Margin="2" SelectedIndex="2" Visibility="Visible">
										<Image Width="20" Margin="0 -2 0 0" Source="/UI/Limbus/Skills/Damage Types/Blunt.png" />
										<Image Width="20" Margin="-3 1 0 0" Source="/UI/Limbus/Skills/Damage Types/Slash.png" />
										<Image Width="22" Margin="-2 -0.3 0 0" Source="/UI/Limbus/Skills/Damage Types/Pierce.png" />
									</InternalStyle:SingleViewer>

								</Grid>

							</Grid>
						</Grid>


						<StackPanel x:Name="PART_NameAndCoins" Margin="133 23 0 0" HorizontalAlignment="Left" VerticalAlignment="Top">

							<StackPanel Orientation="Horizontal">

								<Grid>
									<Limbus:SkillNameReplica_CoinsStackPanelParentBorder Height="25.2" Margin="1 3 0 0" VerticalAlignment="Top" CoinsSequence="{TemplateBinding Coins}" />
									<Limbus:NameLineElement
										x:Name="NameLine"
										Margin="3 32 0 0"
										VerticalAlignment="Top"
										Affinity="{TemplateBinding Affinity}"
										DisplayedName="{TemplateBinding SkillName}"
										DropShadowEffect_Depth="5"
										DropShadowEffect_Direction="230"
										FillColorRightOffsetReduction="35"
										NameMaximumWidth="{TemplateBinding NameMaximumWidth}" />
								</Grid>

							</StackPanel>

							<Grid x:Name="PART_SubIcons" Margin="0 15 0 0">

								<!--    Attack/Defense level    -->
								<Grid>
									<InternalStyle:SingleViewer x:Name="LevelTypeTabs" Visibility="Visible">
										<Image
											x:Name="OffenseLevelIcon"
											Width="38"
											HorizontalAlignment="Left"
											VerticalAlignment="Top"
											Source="/UI/Limbus/Skills/Offense Level.png"
											Visibility="Visible" />
										<Image
											x:Name="DefenseLevelIcon"
											Width="42"
											HorizontalAlignment="Left"
											VerticalAlignment="Top"
											Source="/UI/Limbus/Skills/Defense Level.png"
											Visibility="Visible" />
									</InternalStyle:SingleViewer>

									<StackPanel Margin="47 0 0 0" Orientation="Horizontal">
										<TextBlock
											x:Name="SkillLevel"
											Width="44"
											FontFamily="/UI/Fonts/#EXCELSIOR SANS"
											FontSize="37.5"
											Foreground="#EBCAA2"
											Text="{TemplateBinding LevelText}"
											TextDecorations="Underline"
											Visibility="Visible">
											<TextBlock.Effect>
												<DropShadowEffect BlurRadius="0" Direction="-50" ShadowDepth="2" />
											</TextBlock.Effect>
										</TextBlock>

										<StackPanel x:Name="AttackWeightPanel" Margin="2 12 0 0" HorizontalAlignment="Left" VerticalAlignment="Top" Orientation="Horizontal">
											<Limbus:TMProEmitter
												x:Name="SkillAtkWeightSign"
												Margin="0 -3.5 0 0"
												VerticalAlignment="Center"
												Limbus:AcceptsRichTextDelay="False"
												Limbus:FontType="Context"
												Limbus:RichText="{TemplateBinding AttackWeightLabel}"
												Limbus:TextProcessingMode="None"
												FontSize="15"
												Foreground="#f8c200"
												Visibility="Visible">
												<Limbus:TMProEmitter.Effect>
													<DropShadowEffect BlurRadius="0" Direction="-50" ShadowDepth="0.8" />
												</Limbus:TMProEmitter.Effect>
											</Limbus:TMProEmitter>
											<TextBlock x:Name="SkillAtkWeight" Margin="5 -5.5 0 0" FontSize="20" Foreground="#f8c200" Text="{TemplateBinding AttackWeight, Converter={StaticResource AttackWeightToCharIconsConverter}}">
												<TextBlock.Effect>
													<DropShadowEffect BlurRadius="0" Direction="-50" ShadowDepth="1.5" />
												</TextBlock.Effect>
											</TextBlock>
										</StackPanel>
									</StackPanel>
								</Grid>

							</Grid>
						</StackPanel>


					</Grid>

					<ControlTemplate.Triggers>
						<!--#region Damage type-->
						<Trigger Property="DamageType" Value="Blunt">
							<Setter TargetName="DamageTypesSingleViewer" Property="SelectedIndex" Value="0" />
						</Trigger>
						<Trigger Property="DamageType" Value="Slash">
							<Setter TargetName="DamageTypesSingleViewer" Property="SelectedIndex" Value="1" />
						</Trigger>
						<Trigger Property="DamageType" Value="Pierce">
							<Setter TargetName="DamageTypesSingleViewer" Property="SelectedIndex" Value="2" />
						</Trigger>
						<Trigger Property="DamageType" Value="None">
							<Setter TargetName="DamageTypeParentGrid" Property="Visibility" Value="Collapsed" />
						</Trigger>
						<!--#endregion-->

						<!--    Offense/Defense level    -->
						<Trigger Property="SkillType" Value="Guard">
							<Setter TargetName="LevelTypeTabs" Property="SelectedIndex" Value="1" />
							<Setter TargetName="DamageTypeParentGrid" Property="Visibility" Value="Collapsed" />
						</Trigger>
						<Trigger Property="SkillType" Value="Evade">
							<Setter TargetName="LevelTypeTabs" Property="SelectedIndex" Value="1" />
							<Setter TargetName="DamageTypeParentGrid" Property="Visibility" Value="Collapsed" />
						</Trigger>
						<Trigger Property="SkillType" Value="Counter">
							<Setter TargetName="LevelTypeTabs" Property="SelectedIndex" Value="0" />
						</Trigger>
						<Trigger Property="SkillType" Value="Attack">
							<Setter TargetName="LevelTypeTabs" Property="SelectedIndex" Value="0" />
						</Trigger>
					</ControlTemplate.Triggers>

				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>
</ResourceDictionary>