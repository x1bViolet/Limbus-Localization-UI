												<TextBlock.Effect>
													<DropShadowEffect BlurRadius="0" Direction="-60" ShadowDepth="2.5" />
												</TextBlock.Effect>
											</TextBlock>

											<Grid.RenderTransform>
												<TranslateTransform X="{Binding DataContextDomain.PreviewCreator.ImageInfo.Header.SinnerName.HorizontalOffset, FallbackValue=0}" />
											</Grid.RenderTransform>
										</Grid>
									</StackPanel>

									<StackPanel.RenderTransform>
										<TranslateTransform X="{Binding DataContextDomain.PreviewCreator.ImageInfo.Header.HorizontalOffset, FallbackValue=0}" Y="{Binding DataContextDomain.PreviewCreator.ImageInfo.Header.VerticalOffset, FallbackValue=0}" />
									</StackPanel.RenderTransform>

								</StackPanel>

							</Canvas>
						</Grid>










