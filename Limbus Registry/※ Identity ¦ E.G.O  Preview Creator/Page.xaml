						<!--    StackPanel with Horizontal Orientation is neccessary to normalize default Width of Images with Stretch Uniforming    -->
						<Grid Height="136" VerticalAlignment="Top">
							<Canvas Margin="0 0 800 0" HorizontalAlignment="Right" VerticalAlignment="Bottom">

								<StackPanel Canvas.Right="-280" Canvas.Bottom="0" Orientation="Horizontal">

