														<DropShadowEffect BlurRadius="0" Direction="-90" ShadowDepth="2.15" />
													</TextBlock.Effect>
												</TextBlock>
												<Grid.RenderTransform>
													<TranslateTransform X="{Binding DataContextDomain.PreviewCreator.ImageInfo.Header.IdentityOrEGOName.HorizontalOffset, FallbackValue=0}" />
												</Grid.RenderTransform>
											</Grid>
											<Image Height="33" Margin="-2 0 -12 0" VerticalAlignment="Bottom" Source="{Binding ElementName=VC_Header_RarityOrRiskLevel, Path=SelectedItem.Source}">
