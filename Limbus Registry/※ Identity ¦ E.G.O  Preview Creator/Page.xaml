													<TranslateTransform X="{Binding DataContextDomain.PreviewCreator.ImageInfo.Header.RarityOrRiskLevel.HorizontalOffset, FallbackValue=0}" Y="{Binding DataContextDomain.PreviewCreator.ImageInfo.Header.RarityOrRiskLevel.VerticalOffset, FallbackValue=0}" />
												</Image.RenderTransform>
											</Image>
										</StackPanel>

										<Grid x:Uid="Sinner name" HorizontalAlignment="Right">
