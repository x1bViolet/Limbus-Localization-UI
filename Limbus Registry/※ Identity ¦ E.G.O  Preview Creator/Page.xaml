								<GradientStop Offset="0" Color="#00000000" />
								<GradientStop Offset="0.2" Color="#abcdef" />
								<GradientStop Offset="1" Color="#abcdef" />
							</GradientStopCollection>

							<LinearGradientBrush x:Key="VignettesViewBorder_Top" GradientStops="{StaticResource VignettesViewBorder_GradientStops}" Opacity="0" StartPoint="1 0" EndPoint="1 1" />
							<LinearGradientBrush x:Key="VignettesViewBorder_Bottom" GradientStops="{StaticResource VignettesViewBorder_GradientStops}" Opacity="0" StartPoint="0 1" EndPoint="0 0" />

							<LinearGradientBrush x:Key="VignettesViewBorder_Left" GradientStops="{StaticResource VignettesViewBorder_GradientStops}" Opacity="0" StartPoint="0 1" EndPoint="1 1" />
							<LinearGradientBrush x:Key="VignettesViewBorder_Right" GradientStops="{StaticResource VignettesViewBorder_GradientStops}" Opacity="0" StartPoint="1 1" EndPoint="0 1" />

							<LinearGradientBrush x:Key="VignettesViewBorder_LeftBehindEGOPortrait" Opacity="0" StartPoint="0 1" EndPoint="1 1">
								<GradientStopCollection>
									<GradientStop Offset="0" Color="#00000000" />
									<GradientStop Offset="0.2" Color="#F82D00" />
									<GradientStop Offset="1" Color="#F82D00" />
								</GradientStopCollection>
