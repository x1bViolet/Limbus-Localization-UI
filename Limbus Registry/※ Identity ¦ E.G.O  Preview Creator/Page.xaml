								<TranslateTransform X="{Binding DataContextDomain.PreviewCreator.ImageInfo.TextBackgroundEffects.HorizontalOffset}" Y="{Binding DataContextDomain.PreviewCreator.ImageInfo.TextBackgroundEffects.VerticalOffset}" />
