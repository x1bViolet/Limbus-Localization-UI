												Padding="20 0 25 0"
												FontFamily="{DynamicResource Limbus:TitleFont}"
												FontSize="37"
												FontWeight="{DynamicResource Limbus:TitleFont_Weight}"
												Foreground="#EBCAA2"
												Text="{Binding DataContextDomain.PreviewCreator.ImageInfo.Header.SinnerName.Text, FallbackValue='Sinner'}"
