												<TextBlock
													MaxWidth="500"
													Margin="26 0 26 12"
													VerticalAlignment="Bottom"
													FontFamily="{DynamicResource Limbus:TitleFont}"
													FontSize="21"
													FontWeight="{DynamicResource Limbus:TitleFont_Weight}"
													Foreground="#A66837"
													LineHeight="20.5"
													LineStackingStrategy="BlockLineHeight"
													Text="{Binding DataContextDomain.PreviewCreator.ImageInfo.Header.IdentityOrEGOName.Text, FallbackValue='Identity/E.G.O name', Converter={StaticResource EscapedLineBreaksConverter}}"
													TextAlignment="Center"
													TextWrapping="Wrap">
