<Page
	x:Class="LCLocalizationInterface.LimbusRegistry.PreviewCreator.PreviewCreatorPage"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:Blend="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:DiffPlex="clr-namespace:DiffPlex.Wpf.Controls;assembly=DiffPlex.Wpf"
	xmlns:Entanglement="clr-namespace:LCLocalizationInterface.Entanglement"
	xmlns:Limbus="clr-namespace:LCLocalizationInterface.LimbusRegistry"
	xmlns:LimbusIValueConverters="clr-namespace:LCLocalizationInterface.LimbusRegistry.LimbusIValueConverters"
	xmlns:MarkupCompatibility="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:PreviewCreator="clr-namespace:LCLocalizationInterface.LimbusRegistry.PreviewCreator"
	xmlns:T="clr-namespace:LCLocalizationInterface.MarkupExtensions"
	xmlns:TStyle="clr-namespace:LCLocalizationInterface.Internal.UIStyle"
	xmlns:Terminus="clr-namespace:LCLocalizationInterface.Internal.Terminus"
	xmlns:sys="clr-namespace:System;assembly=mscorlib"
	Blend:DataContext="{Blend:DesignInstance Type=Entanglement:EntanglementModel}"
	Blend:DesignHeight="780"
	Blend:DesignWidth="1532"
	MarkupCompatibility:Ignorable="Blend"
	Background="{DynamicResource Theme:Common.MainWindow.PreviewCreator.Background.Color}"
	DataContext="{Binding Source={StaticResource ThatOnePeskyMvvmThing}}">

	<Viewbox HorizontalAlignment="Center" VerticalAlignment="Center">
		<Grid>

			<Grid x:Name="PreviewCreatorPageContentView" Height="780">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="1121" />
					<ColumnDefinition Width="411" />
				</Grid.ColumnDefinitions>

				<Grid.Resources>
					<Style BasedOn="{StaticResource {x:Type Terminus:IntenseStareType1}}" TargetType="{x:Type Terminus:IntenseStareType1}">
						<Setter Property="Foreground" Value="{DynamicResource Theme:UIText.MainWindow.PreviewCreator.Foreground}" />
						<Setter Property="VerticalAlignment" Value="Center" />
						<Setter Property="FontSize" Value="18.5" />
					</Style>
					<Style x:Key="Theme:ControlStyles.Spec.PreviewCreator.SectionHeader" BasedOn="{StaticResource {x:Type Terminus:IntenseStareType1}}" TargetType="{x:Type Terminus:IntenseStareType1}">
						<Setter Property="FontSize" Value="20" />
						<Setter Property="HorizontalAlignment" Value="Left" />
						<EventSetter Event="MouseLeftButtonUp" Handler="ToggleSecondChildVisibility" />
					</Style>
					<Style BasedOn="{StaticResource Theme:ControlStyles.ComboBox}" TargetType="{x:Type ComboBox}">
						<Setter Property="Height" Value="27" />
						<EventSetter Event="SelectionChanged" Handler="SelectionChanged_Shared" />
					</Style>

					<Style BasedOn="{StaticResource Theme:ControlStyles.CheckBox}" TargetType="{x:Type CheckBox}">
						<Setter Property="IsChecked" Value="False" />
						<Setter Property="Height" Value="27" />
						<Setter Property="Width" Value="27" />
					</Style>

					<Style BasedOn="{StaticResource Theme:ControlStyles.Slider}" TargetType="{x:Type Slider}">
						<EventSetter Event="MouseRightButtonDown" Handler="ResetSliderValue" />
						<Setter Property="VerticalAlignment" Value="Center" />
					</Style>

					<Style BasedOn="{StaticResource Theme:ControlStyles.ElongatedButton}" TargetType="{x:Type Button}">
						<Setter Property="Height" Value="27" />
						<EventSetter Event="MouseRightButtonUp" Handler="ResetSelectedFile" />
					</Style>

					<Style BasedOn="{StaticResource {x:Type Terminus:IntenseStareType3}}" TargetType="{x:Type Terminus:IntenseStareType3}">
						<Setter Property="Height" Value="29" />
						<Setter Property="Padding" Value="1 0.2 0 0" />
						<Setter Property="FontSize" Value="19" />
						<EventSetter Event="RoutedTextChanged" Handler="TextChanged_Shared" />
					</Style>
				</Grid.Resources>

				<!--    Control panel first    -->
				<Grid Grid.Column="1" Width="401" Margin="0 10 0 11" VerticalAlignment="Top">
					<Grid x:Uid="Background image and its shadow">
						<Image HorizontalAlignment="Right" VerticalAlignment="Top" Source="{DynamicResource Theme:Common.MainWindow.PreviewCreator.Background.Image}" Stretch="UniformToFill" />
						<Border Background="{DynamicResource Theme:Common.MainWindow.PreviewCreator.Background.Image.Shadow}" />
					</Grid>
					<StackPanel>
						<TStyle:TwoColumned Height="37">
							<Button Margin="0 0 3 3" Click="OpenImageInfo_ButtonClick" Style="{StaticResource Theme:ControlStyles.ElongatedButton}">
								<Terminus:IntenseStareType1 FontSize="23" PerfectVerticalAlign="True" RichText="Open image info" UID="[C] * Open image info" />
							</Button>
							<Button Grid.Column="1" Margin="3 0 0 3" Click="SaveImageInfo_ButtonClick" Style="{StaticResource Theme:ControlStyles.ElongatedButton}">
								<Terminus:IntenseStareType1 FontSize="23" PerfectVerticalAlign="True" RichText="Save image info" UID="[C] * Save image info" />
							</Button>
						</TStyle:TwoColumned>

						<ScrollViewer Height="722" Style="{StaticResource Theme:ControlStyles.ScrollViewer}">
							<StackPanel x:Name="ImageControlPanel" Margin="2 0 5 0">

								<TStyle:Section x:Uid="Image parameters">

									<Terminus:IntenseStareType1 RichText="[u]Image parameters" Style="{StaticResource Theme:ControlStyles.Spec.PreviewCreator.SectionHeader}" UID="[C] * [Section:Image parameters] Title" />

									<!--    Not TC:OrnamentedSection, rotated slider there    -->
									<Grid x:Uid="This can be collapsed" Margin="0 5 0 0" Visibility="Visible">
										<Grid HorizontalAlignment="Left">
											<Canvas HorizontalAlignment="Right">
												<Terminus:IntenseStareType1 Margin="-41 95 0 0" RichText="Image height" UID="[C] * [Section:Image parameters] Image height">
													<Terminus:IntenseStareType1.RenderTransform>
														<RotateTransform Angle="-90" />
													</Terminus:IntenseStareType1.RenderTransform>
												</Terminus:IntenseStareType1>
											</Canvas>
											<Slider
												Margin="19 0 0 -4.5"
												VerticalAlignment="Stretch"
												Focusable="False"
												Maximum="1900"
												Minimum="400"
												Orientation="Vertical"
												RenderTransformOrigin="0.5 0.5"
												TickFrequency="742"
												Value="{Binding DataContextDomain.PreviewCreator.ImageInfo.Height, FallbackValue=742}">
												<Slider.RenderTransform>
													<RotateTransform Angle="180" />
												</Slider.RenderTransform>
											</Slider>
										</Grid>
										<StackPanel Margin="45 0 0 0" VerticalAlignment="Top">
											<StackPanel MouseEnter="ImageWidthSlider_MouseEnter_UnsealCautions" MouseLeave="ImageWidthSlider_MouseLeave_SealCautions">
												<Slider
													x:Name="VC_ImageWidth_FirstStep"
													Maximum="1084"
													Minimum="560"
													TickFrequency="1084"
													ValueChanged="ImageWidth_FirstStep_SliderValueChanged"
													Value="1084" />
												<Terminus:IntenseStareType1 RichText="Image width (First step)" UID="[C] * [Section:Image parameters] Image width (First step)" />
											</StackPanel>
											<StackPanel MouseEnter="ImageWidthSlider_MouseEnter_UnsealCautions" MouseLeave="ImageWidthSlider_MouseLeave_SealCautions" Margin="0 5 0 0">
												<Slider
													x:Name="VC_ImageWidth_SecondStep"
													Maximum="1900"
													Minimum="1084"
													TickFrequency="1084"
													ValueChanged="ImageWidth_SecondStep_SliderValueChanged"
													Value="1084" />
												<Terminus:IntenseStareType1 RichText="Image width (Second step)" UID="[C] * [Section:Image parameters] Image width (Second step)" />
											</StackPanel>

											<TStyle:Section x:Uid="Portrait image" Margin="0 8 0 0">

												<Terminus:IntenseStareType1 RichText="[u]Portrait image" Style="{StaticResource Theme:ControlStyles.Spec.PreviewCreator.SectionHeader}" UID="[C] * [Section:Image parameters / Portrait image] Title" />

												<PreviewCreator:OrnamentedSection x:Uid="This can be collapsed" Visibility="Visible">
													<StackPanel Grid.Column="1">

														<TStyle:TwoColumned>
															<Terminus:IntenseStareType1 Margin="0 0 5 0" RichText="Portrait image: [b][size=82%]..." UID="[C] * [Section:Image parameters / Portrait image] Portrait image (Label)" />
															<Button x:Name="SelectPortraitImage_Button" Grid.Column="1" Click="SelectPortraitImage_ButtonClick">
																<Terminus:IntenseStareType1 RichText="Select image file" UID="[C] * [Section:Image parameters / Portrait image] Portrait image (Button)" />
															</Button>
														</TStyle:TwoColumned>

														<TStyle:TwoColumned Margin="0 8 0 0">
															<Terminus:IntenseStareType1 PerfectVerticalAlign="True" RichText="Portrait type" UID="[C] * [Section:Image parameters / Portrait image] Portrait type" />
															<ComboBox x:Name="VC_PortraitType" Grid.Column="1" Padding="6 2 6 0" SelectedIndex="0">
																<ComboBox.Items>
																	<Terminus:IntenseStareType1 x:Uid="Identity" DataContext="※This is an unofficial Identity Preview image created with 'LC Localization Interface' program" RichText="Identity" UID="[C] * [Section:Image parameters / Portrait image] Portrait type — Identity" />
																	<Terminus:IntenseStareType1 x:Uid="E.G.O" DataContext="※This is an unofficial E.G.O Preview image created with 'LC Localization Interface' program" RichText="E.G.O" UID="[C] * [Section:Image parameters / Portrait image] Portrait type — E.G.O" />
																</ComboBox.Items>
															</ComboBox>
														</TStyle:TwoColumned>

														<TStyle:TwoColumned Margin="0 8 0 0">
															<Terminus:IntenseStareType1 PerfectVerticalAlign="True" RichText="Horizontal offset" UID="[C] * [Section:Image parameters / Portrait image] Horizontal offset" />
															<Slider
																x:Name="VC_PortraitImage_HorizontalOffset"
																Grid.Column="1"
																Maximum="1000"
																Minimum="-1000"
																TickFrequency="0"
																Value="{Binding DataContextDomain.PreviewCreator.ImageInfo.Portrait.HorizontalOffset, FallbackValue=0}" />
														</TStyle:TwoColumned>

														<TStyle:TwoColumned Margin="0 8 0 0">
															<Terminus:IntenseStareType1 PerfectVerticalAlign="True" RichText="Vertical offset" UID="[C] * [Section:Image parameters / Portrait image] Vertical offset" />
															<Slider
																x:Name="VC_PortraitImage_VerticalOffset"
																Grid.Column="1"
																Maximum="1000"
																Minimum="-1000"
																TickFrequency="0"
																Value="{Binding DataContextDomain.PreviewCreator.ImageInfo.Portrait.VerticalOffset, FallbackValue=0}" />
														</TStyle:TwoColumned>

													</StackPanel>
												</PreviewCreator:OrnamentedSection>

											</TStyle:Section>






											<TStyle:Section x:Uid="Portrait parameters [Identity]" Margin="0 8 0 0">

												<Terminus:IntenseStareType1 RichText="[u]Portrait parameters [Identity]" Style="{StaticResource Theme:ControlStyles.Spec.PreviewCreator.SectionHeader}" UID="[C] * [Section:Image parameters / Portrait parameters [Identity]] Title" />

												<PreviewCreator:OrnamentedSection x:Uid="This can be collapsed" Visibility="Visible">

													<StackPanel x:Name="IdentityPortraitImageParametersPanel" Grid.Column="1">
														<Slider
															x:Name="VC_IdentityPortraitScale"
															LargeChange="0.003"
															Maximum="3"
															Minimum="0.5"
															TickFrequency="1"
															Value="{Binding DataContextDomain.PreviewCreator.ImageInfo.Portrait.Identity.Scale, FallbackValue=1}" />
														<Terminus:IntenseStareType1 RichText="Image scale" UID="[C] * [Section:Image parameters / Portrait parameters [Identity]] Image scale" />
													</StackPanel>
												</PreviewCreator:OrnamentedSection>

											</TStyle:Section>






											<TStyle:Section x:Uid="Portrait parameters [E.G.O]" Margin="0 8 0 0">

												<Terminus:IntenseStareType1 RichText="[u]Portrait parameters [E.G.O]" Style="{StaticResource Theme:ControlStyles.Spec.PreviewCreator.SectionHeader}" UID="[C] * [Section:Image parameters / Portrait parameters [E.G.O]] Title" />

												<PreviewCreator:OrnamentedSection x:Uid="This can be collapsed" Visibility="Visible">

													<StackPanel x:Name="EGOPortraitImageParametersPanel" Grid.Column="1" IsHitTestVisible="False" Opacity="0.55">

														<TStyle:TwoColumned>
															<Terminus:IntenseStareType1 PerfectVerticalAlign="True" RichText="Inner image scale" UID="[C] * [Section:Image parameters / Portrait parameters [E.G.O]] Inner image scale" />
															<Slider
																x:Name="VC_EGOInnerPortraiScale"
																Grid.Column="1"
																LargeChange="0.003"
																Maximum="3"
																Minimum="0.1"
																TickFrequency="1"
																Value="{Binding DataContextDomain.PreviewCreator.ImageInfo.Portrait.EGO.InnerImageScale, FallbackValue=1}" />
														</TStyle:TwoColumned>

														<TStyle:TwoColumned Margin="0 5 0 0">
															<Terminus:IntenseStareType1 PerfectVerticalAlign="True" RichText="Scale with frame" UID="[C] * [Section:Image parameters / Portrait parameters [E.G.O]] Scale with frame" />
															<Slider
																x:Name="VC_EGOWholePortraiScale"
																Grid.Column="1"
																LargeChange="0.001"
																Maximum="2"
																Minimum="0.7"
																TickFrequency="1"
																Value="{Binding DataContextDomain.PreviewCreator.ImageInfo.Portrait.EGO.WholeImageScale, FallbackValue=1}" />
														</TStyle:TwoColumned>

														<TStyle:TwoColumned Margin="0 5 0 0">
															<Terminus:IntenseStareType1 Margin="0 0 5 0" PerfectVerticalAlign="True" RichText="Frame color" UID="[C] * [Section:Image parameters / Portrait parameters [E.G.O]] Frame color" />
															<Terminus:IntenseStareType3 x:Name="VC_EGOPortrait_FrameColorInput" Grid.Column="1" BindableText="{Binding DataContextDomain.PreviewCreator.ImageInfo.Portrait.EGO.FrameColor, FallbackValue='ffffff'}" DisplayInputColor="True" UID="[C] * [Section:Image parameters / Portrait parameters [E.G.O]] Frame color" />
														</TStyle:TwoColumned>

													</StackPanel>

												</PreviewCreator:OrnamentedSection>

											</TStyle:Section>






											<TStyle:Section x:Uid="Vignette additional length" Margin="0 8 0 0">

												<Terminus:IntenseStareType1 RichText="[u]Vignette additional length" Style="{StaticResource Theme:ControlStyles.Spec.PreviewCreator.SectionHeader}" UID="[C] * [Section:Image parameters / Vignette additional length] Title" />

												<PreviewCreator:OrnamentedSection x:Uid="This can be collapsed" Visibility="Visible">

													<StackPanel Grid.Column="1">

														<Grid Margin="0 5 0 0">
															<Grid.ColumnDefinitions>
																<ColumnDefinition />
																<ColumnDefinition />
																<ColumnDefinition />
															</Grid.ColumnDefinitions>

															<StackPanel x:Name="TopVignetteAddLengthAdjustPanel" Margin="0 0 2 0" MouseEnter="HighlightVignette_Top" MouseLeave="UnHighlightVignette_Top">
																<Slider
																	x:Name="VC_TopVignettePlusLength"
																	Maximum="900"
																	Minimum="-500"
																	TickFrequency="0"
																	ValueChanged="TopVignettePlusLength_NegativeValueHandler"
																	Value="{Binding DataContextDomain.PreviewCreator.ImageInfo.Vignette.PlusLength.Top, FallbackValue=0}" />
																<Terminus:IntenseStareType1 RichText="Top" TextAlignment="Center" UID="[C] * [Section:Image parameters / Vignette additional length] Top" />
															</StackPanel>
															<StackPanel Grid.Column="1" Margin="2 0 2 0" MouseEnter="HighlightVignette_Left" MouseLeave="UnHighlightVignette_Left">
																<Slider
																	x:Name="VC_LeftVignettePlusLength"
																	Maximum="900"
																	Minimum="-500"
																	TickFrequency="0"
																	ValueChanged="LeftVignettePlusLength_NegativeValueHandler"
																	Value="{Binding DataContextDomain.PreviewCreator.ImageInfo.Vignette.PlusLength.Left, FallbackValue=0}" />
																<Terminus:IntenseStareType1 RichText="Left" TextAlignment="Center" UID="[C] * [Section:Image parameters / Vignette additional length] Left" />
															</StackPanel>
															<StackPanel x:Name="BottomVignetteAddLengthAdjustPanel" Grid.Column="2" Margin="2 0 0 0" MouseEnter="HighlightVignette_Bottom" MouseLeave="UnHighlightVignette_Bottom">
																<Slider
																	x:Name="VC_BottomVignettePlusLength"
																	Maximum="900"
																	Minimum="-500"
																	TickFrequency="0"
																	ValueChanged="BottomVignettePlusLength_NegativeValueHandler"
																	Value="{Binding DataContextDomain.PreviewCreator.ImageInfo.Vignette.PlusLength.Bottom, FallbackValue=0}" />
																<Terminus:IntenseStareType1 RichText="Bottom" TextAlignment="Center" UID="[C] * [Section:Image parameters / Vignette additional length] Bottom" />
															</StackPanel>
														</Grid>

														<StackPanel Grid.Column="1" Margin="0 5 0 0" MouseEnter="HighlightVignette_Right" MouseLeave="UnHighlightVignette_Right">
															<Slider
																x:Name="VC_RightVignettePlusLength"
																Maximum="1700"
																Minimum="-500"
																TickFrequency="600"
																ValueChanged="RightVignettePlusLength_NegativeValueHandler"
																Value="{Binding DataContextDomain.PreviewCreator.ImageInfo.Vignette.PlusLength.Right, FallbackValue=600}" />
															<Terminus:IntenseStareType1 RichText="Right [b](Text background)[/b]" UID="[C] * [Section:Image parameters / Vignette additional length] Right (Text background)" />
														</StackPanel>

														<StackPanel
															x:Name="LeftBehindEGOPortraitVignettePlusLengthPanel"
															Grid.Column="1"
															Margin="0 5 0 0"
															IsHitTestVisible="False"
															MouseEnter="HighlightVignette_LeftBehindEGOPortrait"
															MouseLeave="UnHighlightVignette_LeftBehindEGOPortrait"
															Opacity="0.55">
															<Slider
																x:Name="VC_LeftBehindEGOVignettePlusLength"
																Maximum="900"
																Minimum="-500"
																TickFrequency="0"
																ValueChanged="LeftBehindEGOVignettePlusLength_NegativeValueHandler"
																Value="{Binding DataContextDomain.PreviewCreator.ImageInfo.Vignette.PlusLength.Left_BehindEGOPortrait, FallbackValue=0}" />
															<Terminus:IntenseStareType1 RichText="Left behind E.G.O portrait [color=#919188][b][font=&quot;Times New Roman&quot;][&#x200b;i]" ToolTipService.InitialShowDelay="100" UID="[C] * [Section:Image parameters / Vignette additional length] Left behind E.G.O portrait">
																<Terminus:IntenseStareType1.ToolTip>
																	<ToolTip Style="{StaticResource Theme:ControlStyles.Tooltip}">
																		<Terminus:IntenseStareType1 FontSize="15" Foreground="{DynamicResource Theme:UIText.MainWindow.PreviewCreator.Foreground.Tooltips}" LineHeight="18" RichText="Designed to shade Text Background Effects" UID="[C] * [Section:Image parameters / Vignette additional length] Left behind E.G.O portrait (Tooltip info)" />
																	</ToolTip>
																</Terminus:IntenseStareType1.ToolTip>
															</Terminus:IntenseStareType1>
														</StackPanel>

													</StackPanel>

												</PreviewCreator:OrnamentedSection>

											</TStyle:Section>






											<TStyle:Section x:Uid="Vignette softness" Margin="0 8 0 0">

												<Terminus:IntenseStareType1 RichText="[u]Vignette softness" Style="{StaticResource Theme:ControlStyles.Spec.PreviewCreator.SectionHeader}" UID="[C] * [Section:Image parameters / Vignette softness] Title" />

												<PreviewCreator:OrnamentedSection x:Uid="This can be collapsed" Visibility="Collapsed">

													<StackPanel Grid.Column="1">

														<StackPanel Grid.Column="1" Margin="0 5 0 0" MouseEnter="HighlightVignette_LeftTopBottom" MouseLeave="UnHighlightVignette_LeftTopBottom">
															<Slider x:Name="VC_LeftTopBottomVignetteSoftness" Maximum="500" Minimum="0" TickFrequency="40" Value="{Binding DataContextDomain.PreviewCreator.ImageInfo.Vignette.Softness.LeftTopBottom, FallbackValue=40}" />
															<Terminus:IntenseStareType1 RichText="Left / Top / Bottom  [b](General)[/b]" UID="[C] * [Section:Image parameters / Vignette softness] Left / Top / Bottom (General)" />
														</StackPanel>

														<StackPanel Grid.Column="1" Margin="0 5 0 0" MouseEnter="HighlightVignette_Right" MouseLeave="UnHighlightVignette_Right">
															<Slider x:Name="VC_RightVignetteSoftness" Maximum="500" Minimum="0" TickFrequency="140" Value="{Binding DataContextDomain.PreviewCreator.ImageInfo.Vignette.Softness.Right, FallbackValue=140}" />
															<Terminus:IntenseStareType1 RichText="Right [b](Text background)[/b]" UID="[C] * [Section:Image parameters / Vignette softness] Right (Text background)" />
														</StackPanel>

														<StackPanel
															x:Name="LeftBehindEGOPortraitVignetteSoftnessPanel"
															Grid.Column="1"
															Margin="0 5 0 0"
															IsHitTestVisible="False"
															MouseEnter="HighlightVignette_LeftBehindEGOPortrait"
															MouseLeave="UnHighlightVignette_LeftBehindEGOPortrait"
															Opacity="0.55">
															<Slider x:Name="VC_LeftBehindEGOVignetteSoftness" Maximum="600" Minimum="0" TickFrequency="0" Value="{Binding DataContextDomain.PreviewCreator.ImageInfo.Vignette.Softness.Left_BehindEGOPortrait, FallbackValue=0}" />
															<Terminus:IntenseStareType1 RichText="Left behind E.G.O portrait [color=#919188][b][font=&quot;Times New Roman&quot;][&#x200b;i]" ToolTipService.InitialShowDelay="100" UID="[C] * [Section:Image parameters / Vignette softness] Left behind E.G.O portrait">
																<Terminus:IntenseStareType1.ToolTip>
																	<ToolTip Style="{StaticResource Theme:ControlStyles.Tooltip}">
																		<Terminus:IntenseStareType1 FontSize="15" Foreground="{DynamicResource Theme:UIText.MainWindow.PreviewCreator.Foreground.Tooltips}" LineHeight="18" RichText="Designed to shade Text Background Effects" UID="[C] * [Section:Image parameters / Vignette softness] Left behind E.G.O portrait (Tooltip info)" />
																	</ToolTip>
																</Terminus:IntenseStareType1.ToolTip>
															</Terminus:IntenseStareType1>
														</StackPanel>

													</StackPanel>

												</PreviewCreator:OrnamentedSection>

											</TStyle:Section>






											<TStyle:Section x:Uid="Image label" Margin="0 8 0 0">

												<Terminus:IntenseStareType1 RichText="[u]Image label" Style="{StaticResource Theme:ControlStyles.Spec.PreviewCreator.SectionHeader}" UID="[C] * [Section:Image parameters / Image label] Title" />

												<PreviewCreator:OrnamentedSection x:Uid="This can be collapsed" Visibility="Visible">

													<StackPanel Grid.Column="1">

														<TStyle:TwoColumned>
															<Terminus:IntenseStareType1 Margin="0 0 5 0" PerfectVerticalAlign="True" RichText="Image label text" UID="[C] * [Section:Image parameters / Image label] Image label text" />
															<Terminus:IntenseStareType3 x:Name="VC_RightCornerLabelInput" Grid.Column="1" BindableText="{Binding DataContextDomain.PreviewCreator.ImageInfo.ImageLabelText.Text, UpdateSourceTrigger=PropertyChanged, FallbackValue='IDENTITY INFO'}" UID="[C] * [Section:Image parameters / Image label] Image label text" />
														</TStyle:TwoColumned>

														<TStyle:TwoColumned Margin="0 5 0 0">
															<Terminus:IntenseStareType1 Margin="0 0 5 0" PerfectVerticalAlign="True" RichText="Image label font" UID="[C] * [Section:Image parameters / Image label] Image label font (Label)" />
															<Button x:Name="SelectImageLabelFont_Button" Grid.Column="1" Click="SelectImageLabelFont_ButtonClick">
																<Terminus:IntenseStareType1 RichText="Select font file" UID="[C] * [Section:Image parameters / Image label] Image label font (Button)" />
															</Button>
														</TStyle:TwoColumned>

														<TStyle:TwoColumned Margin="0 5 0 0">
															<Terminus:IntenseStareType1 PerfectVerticalAlign="True" RichText="Text size" UID="[C] * [Section:Image parameters / Image label] Text size" />
															<Slider
																x:Name="VC_LabelTextSize"
																Grid.Column="1"
																Maximum="120"
																Minimum="50"
																TickFrequency="80"
																Value="{Binding DataContextDomain.PreviewCreator.ImageInfo.ImageLabelText.Size, FallbackValue=80}" />
														</TStyle:TwoColumned>

														<TStyle:TwoColumned Margin="0 5 0 0">
															<Terminus:IntenseStareType1 PerfectVerticalAlign="True" RichText="Vertical offset" UID="[C] * [Section:Image parameters / Image label] Vertical offset" />
															<Slider
																x:Name="VC_LabelVertialOffset"
																Grid.Column="1"
																Maximum="40"
																Minimum="-40"
																TickFrequency="0"
