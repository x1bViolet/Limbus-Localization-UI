<ResourceDictionary
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:InternalStyle="clr-namespace:LCLocalizationInterface.Internal.UIStyle"
	xmlns:Limbus="clr-namespace:LCLocalizationInterface.LimbusRegistry"
	xmlns:LimbusIValueConverters="clr-namespace:LCLocalizationInterface.LimbusRegistry.LimbusIValueConverters"
	xmlns:PreviewCreator="clr-namespace:LCLocalizationInterface.LimbusRegistry.PreviewCreator">

	<ResourceDictionary.MergedDictionaries>
		<!--    Its not inherinted from main app's ※ Entanglement Dictionary.xaml!!!!!!!!!!!!!    -->
		<ResourceDictionary Source="/Internal/Resource Dictionaries/IValueConverters.xaml" />
	</ResourceDictionary.MergedDictionaries>

	<Style TargetType="{x:Type PreviewCreator:SkillNameReplicaUIElement_PCE}">
		<Setter Property="Affinity" Value="None" />

		<Setter Property="DamageType" Value="None" />
		<Setter Property="SkillType" Value="Attack" />

		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="{x:Type PreviewCreator:SkillNameReplicaUIElement_PCE}">

					<ControlTemplate.Resources>
						<LimbusIValueConverters:AffinityAndRankToSkillFrameConverter x:Key="AffinityAndRankToSkillFrameConverter" />
					</ControlTemplate.Resources>

					<StackPanel Orientation="Horizontal">

						<Grid x:Name="PART_Icon" Margin="-16 -13 0 0" HorizontalAlignment="Left" VerticalAlignment="Top">

							<Grid HorizontalAlignment="Left" VerticalAlignment="Top">

								<!--    To share color for DropShadowEffects via Bindings as System.Windows.Media.Color instead of SolidColorBrush    -->
								<Border x:Name="AffinityColorCarrier" Background="{TemplateBinding InternalAffinityColor}" Visibility="Collapsed" />


								<Grid>
									<!--    Skill Icon    -->
									<Grid Height="{Binding Width, RelativeSource={RelativeSource Self}}" Margin="32" Background="{TemplateBinding InternalAffinityColor}">
										<Grid>
											<Image x:Uid="Icon image" Width="75" Source="{TemplateBinding Icon}" />
										</Grid>
										<Grid.OpacityMask>
											<ImageBrush ImageSource="/UI/Limbus/Skills/Icon Opacity Mask.png" />
										</Grid.OpacityMask>
									</Grid>

									<!--    Frame (Affinity)    -->
									<Image x:Name="AffinityFrame" Width="{Binding Path=Height, RelativeSource={RelativeSource Self}}" Height="145" Source="{TemplateBinding AffinityAndRank, Converter={StaticResource AffinityAndRankToSkillFrameConverter}}" />
								</Grid>


								<!--    Damage type    -->
								<Grid
									x:Name="DamageTypeParentGrid"
									Width="32"
									Height="{Binding Width, RelativeSource={RelativeSource Self}}"
									Margin="-1 0 0 18.6"
									VerticalAlignment="Bottom"
									Opacity="1"
									RenderTransformOrigin="0.5 1">
									<Grid.Resources>
										<Style TargetType="{x:Type Border}">
											<Setter Property="OpacityMask">
												<Setter.Value>
													<ImageBrush ImageSource="/UI/Limbus/Skills/Damage Type Opacity Mask.png" />
												</Setter.Value>
											</Setter>
										</Style>
									</Grid.Resources>

									<!--    Frame    -->
									<Border Background="{TemplateBinding InternalAffinityColor}">
										<Border Padding="2">
											<Border Background="#7A000000">
												<Border Margin="3" Background="#1b1c1b" />
											</Border>
										</Border>
									</Border>

									<!--    Icons    -->
									<InternalStyle:SingleViewer x:Name="DamageTypesSingleViewer" SelectedIndex="1" Visibility="Visible">
										<Image Margin="5.5 1 2 3" Source="/UI/Limbus/Skills/Damage Types/Blunt.png" />
										<Image Margin="-1 3.5 0 2" Source="/UI/Limbus/Skills/Damage Types/Slash.png" />
										<Image Margin="3.5 0 2 0" Source="/UI/Limbus/Skills/Damage Types/Pierce.png" />
									</InternalStyle:SingleViewer>

								</Grid>

							</Grid>

						</Grid>

						<StackPanel x:Name="PART_NameAndCoins" Margin="-23 0 0 0" HorizontalAlignment="Left" VerticalAlignment="Top">

							<StackPanel Orientation="Horizontal">
								<Image
									x:Name="AffinityIcon"
									Height="35"
									Margin="0 16 1.2 0"
									VerticalAlignment="Top"
									Source="{TemplateBinding InternalAffinityIcon}"
									Visibility="Visible" />
								<StackPanel Margin="0 9.5 0 0">
									<Limbus:SkillNameReplica_CoinsStackPanelParentBorder Height="17.5" VerticalAlignment="Bottom" CoinsSequence="{TemplateBinding Coins}" />
									<Limbus:NameLineElement
										x:Name="SkillNameDisplayer"
										Margin="0 3 0 0"
										VerticalAlignment="Top"
										Affinity="{TemplateBinding Affinity}"
										DisplayedName="{TemplateBinding SkillName}"
										FillColorRightOffsetReduction="32"
										NameMaximumWidth="{TemplateBinding NameMaximumWidth}">
										<Limbus:NameLineElement.LayoutTransform>
											<ScaleTransform ScaleX="0.667" ScaleY="{Binding ScaleX, RelativeSource={RelativeSource Self}}" />
										</Limbus:NameLineElement.LayoutTransform>
									</Limbus:NameLineElement>
								</StackPanel>
							</StackPanel>

							<!--
								Special offset adder to emitate SkillNameDisplayer Height despite its LayoutTransform,
								using RenderTransform creates a phantom extra size beyond the actual visual size :/
							-->
							<Border Height="{Binding ElementName=SkillNameDisplayer, Path=ActualHeight}" Margin="{Binding ElementName=SkillNameDisplayer, Path=ActualHeight, Converter={StaticResource DoubleToNegativeTopMarginConverter}}" />

							<ContentPresenter Margin="0 2.5 0 0" Content="{TemplateBinding SkillLocalizationTextView}" />

						</StackPanel>

					</StackPanel>

					<ControlTemplate.Triggers>
						<!--#region Damage type-->
						<Trigger Property="DamageType" Value="Blunt">
							<Setter TargetName="DamageTypesSingleViewer" Property="SelectedIndex" Value="0" />
						</Trigger>
						<Trigger Property="DamageType" Value="Slash">
							<Setter TargetName="DamageTypesSingleViewer" Property="SelectedIndex" Value="1" />
						</Trigger>
						<Trigger Property="DamageType" Value="Pierce">
							<Setter TargetName="DamageTypesSingleViewer" Property="SelectedIndex" Value="2" />
						</Trigger>
						<Trigger Property="DamageType" Value="None">
							<Setter TargetName="DamageTypeParentGrid" Property="Visibility" Value="Collapsed" />
						</Trigger>
						<Trigger Property="SkillType" Value="Guard">
							<Setter TargetName="DamageTypeParentGrid" Property="Visibility" Value="Collapsed" />
						</Trigger>
						<!--#endregion-->

						<Trigger Property="ShowAffinityIcon" Value="False">
							<Setter TargetName="AffinityIcon" Property="Visibility" Value="Collapsed" />
						</Trigger>
					</ControlTemplate.Triggers>

				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>
</ResourceDictionary>