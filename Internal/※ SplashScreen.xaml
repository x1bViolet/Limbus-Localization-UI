<Window
	x:Class="LCLocalizationInterface.Internal.SplashScreenWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:Terminus="clr-namespace:LCLocalizationInterface.Internal.Terminus"
	SizeToContent="WidthAndHeight"
	Style="{StaticResource Base:WindowLayout}"
	Topmost="True"
	ShowInTaskbar="False"
	WindowStartupLocation="CenterScreen">
	<StackPanel>
		<StackPanel.Resources>
			<Style TargetType="{x:Type Terminus:IntenseStareType1}">
				<Setter Property="FontFamily" Value="/UI/Fonts/#GOST Type BU" />
				<Setter Property="FontWeight" Value="Bold" />
				<Setter Property="Foreground" Value="#C6C3BD" />
				<Setter Property="TextAlignment" Value="Center" />
				<Setter Property="Width" Value="300" />
			</Style>
		</StackPanel.Resources>
		<Image x:Name="ShownImage" Width="300" Height="300" RenderOptions.BitmapScalingMode="Fant" Source="/UI/Logo.png"/>
		<StackPanel x:Name="Texts" Margin="0 8 0 0">
			<Terminus:IntenseStareType1 x:Name="ProgressObjectTextBlock" FontSize="20" />
			<Terminus:IntenseStareType1 x:Name="ProgressSubObjectTextBlock" FontSize="17" />
			<StackPanel.Effect>
				<DropShadowEffect BlurRadius="0" Direction="-90" ShadowDepth="1.4" />
			</StackPanel.Effect>
		</StackPanel>
	</StackPanel>
</Window>