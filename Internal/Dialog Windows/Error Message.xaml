<Abstractions:DialogWindowBase
	x:Class="LCLocalizationInterface.Internal.ErrorMessageWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:Abstractions="clr-namespace:LCLocalizationInterface.Internal.Abstractions"
	xmlns:TStyle="clr-namespace:LCLocalizationInterface.Internal.UIStyle"
	xmlns:Terminus="clr-namespace:LCLocalizationInterface.Internal.Terminus"
	Title="{Binding ElementName=CaptionBinder, Path=Text}"
	MaxWidth="930"
	Style="{StaticResource Base:WindowLayout.DialogWindow}">
	<TStyle:InstancedWindowLayout BorderBrush="{DynamicResource Theme:Common.DialogWindows.Border.Color}" CornerRadius="{DynamicResource Theme:Common.DialogWindows.Border.CornerRadius}" HasPaddedDropShadow="True">
		
		<TStyle:InstancedWindowLayout.Title>
			<Terminus:IntenseStareType1 RichText=" Occurred Exception" Style="{StaticResource Base:WindowLayout.TitleBar.TitleText}" UID="[Error Message] * Title" />
		</TStyle:InstancedWindowLayout.Title>

		<TStyle:InstancedWindowLayout.Navigation>
			<Button Click="Minimize" Style="{StaticResource Base:TitleBar.Button.Defaults.Minimize}" />
			<Button Click="FadeClose" Style="{StaticResource Base:TitleBar.Button.Defaults.Close}" />
		</TStyle:InstancedWindowLayout.Navigation>

		<TStyle:InstancedWindowLayout.Content>
			<Grid Background="{DynamicResource Theme:Common.DialogWindows.Background.Color}">

				<Terminus:IntenseStareType1 Text="Occurred Exception" x:Name="CaptionBinder" x:FieldModifier="private" UID="[Error Message] [!] [#] * Title (Window caption)" Visibility="Collapsed" />

				<Abstractions:DialogWindowContentPresenter>
					<StackPanel>
						<TStyle:TwoColumned Width1="80">
							<Image x:Name="ZenaImage" Margin="0 10 0 0" VerticalAlignment="Top" Source="/UI/Limbus/Zena Cat/기둥 야옹.png" />
							<ScrollViewer Grid.Column="1" MaxHeight="600" Style="{StaticResource Theme:ControlStyles.ScrollViewer}" VerticalScrollBarVisibility="Auto">
								<Terminus:IntenseStareType1
									x:Name="ErrorTextBlock"
									Margin="13 0 5 0"
									VerticalAlignment="Top"
									FontFamily="Consolas"
									FontSize="12"
									LineHeight="25"
									TextAlignment="Left"
									UID="[Error Message] [-] * Text" />
							</ScrollViewer>
						</TStyle:TwoColumned>
						<StackPanel Margin="0 10 0 0" HorizontalAlignment="Center" Orientation="Horizontal">
							<Button Click="FadeClose" Style="{StaticResource Theme:ControlStyles.ElongatedButton}">
								<Terminus:IntenseStareType1 Padding="20 0 20 0" FontSize="20" RichText="OK.." TextAlignment="Center" UID="[Error Message] * OK Button" />
							</Button>
							<Button
								x:Name="AddExceptionToIgnoreList_Button"
								Margin="5 0 0 0"
								Click="AddExceptionToIgnoreList_ButtonClick"
								Style="{StaticResource Theme:ControlStyles.ElongatedButton}"
								ToolTip="[⇲] Assets Directory\※ Internal\Ignored Exceptions.json"
								ToolTipService.ShowOnDisabled="True">
								<Terminus:IntenseStareType1 Padding="20 0 20 0" FontSize="20" RichText="Add to ignore list" TextAlignment="Center" UID="[Error Message] * Add to ignore list" />
							</Button>
						</StackPanel>
					</StackPanel>
				</Abstractions:DialogWindowContentPresenter>

			</Grid>
		</TStyle:InstancedWindowLayout.Content>
	
	</TStyle:InstancedWindowLayout>

</Abstractions:DialogWindowBase>