<Abstractions:DialogWindowBase
	x:Class="LCLocalizationInterface.Internal.InputDialog"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:Abstractions="clr-namespace:LCLocalizationInterface.Internal.Abstractions"
	xmlns:TStyle="clr-namespace:LCLocalizationInterface.Internal.UIStyle"
	xmlns:Terminus="clr-namespace:LCLocalizationInterface.Internal.Terminus"
	Title="{Binding ElementName=CaptionBinder, Path=Text}"
	PreviewKeyDown="InputDialog_PreviewKeyDown"
	Style="{StaticResource Base:WindowLayout.DialogWindow}">

	<TStyle:InstancedWindowLayout Width="332" Height="134" BorderBrush="{DynamicResource Theme:Common.DialogWindows.Border.Color}" CornerRadius="{DynamicResource Theme:Common.DialogWindows.Border.CornerRadius}" HasPaddedDropShadow="True">

		<TStyle:InstancedWindowLayout.Title>
			<Terminus:IntenseStareType1 Style="{StaticResource Base:WindowLayout.TitleBar.TitleText}" UID="[Input Dialog] * Title" Cursor="Hand" />
		</TStyle:InstancedWindowLayout.Title>

		<TStyle:InstancedWindowLayout.Navigation>
			<Button Click="FadeClose" Style="{StaticResource Base:TitleBar.Button.Defaults.Close}" />
		</TStyle:InstancedWindowLayout.Navigation>

		<TStyle:InstancedWindowLayout.Content>
			<Grid Background="{DynamicResource Theme:Common.DialogWindows.Background.Color}">

				<Terminus:IntenseStareType1 x:Name="CaptionBinder" UID="[Input Dialog] [!] [#] * Title (Window caption)" Visibility="Collapsed" />

				<Abstractions:DialogWindowContentPresenter ViewPadding="8">
					<TStyle:TwoColumned Height="33" Width2="33">
						<Terminus:IntenseStareType3 x:Name="InputTextBox" Margin="0 0 4 0" FontSize="21" TextChanged="InputTextBox_TextChanged" UID="[Input Dialog] * Text Input" />
						<Button
							x:Name="ConfirmButton"
							Grid.Column="1"
							Click="Confirm_ButtonClick"
							Content=""
							FontSize="22"
							Style="{StaticResource Theme:ControlStyles.SquareButton}" />
					</TStyle:TwoColumned>
				</Abstractions:DialogWindowContentPresenter>

			</Grid>
		</TStyle:InstancedWindowLayout.Content>

	</TStyle:InstancedWindowLayout>

</Abstractions:DialogWindowBase>