<Abstractions:DialogWindowBase
	x:Class="LCLocalizationInterface.Internal.UpdateNoticeWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:Abstractions="clr-namespace:LCLocalizationInterface.Internal.Abstractions"
	xmlns:TStyle="clr-namespace:LCLocalizationInterface.Internal.UIStyle"
	xmlns:Terminus="clr-namespace:LCLocalizationInterface.Internal.Terminus"
	Title="{Binding ElementName=CaptionBinder, Path=Text}"
	Style="{StaticResource Base:WindowLayout.DialogWindow}">

	<TStyle:InstancedWindowLayout BorderBrush="{DynamicResource Theme:Common.DialogWindows.Border.Color}" CornerRadius="{DynamicResource Theme:Common.DialogWindows.Border.CornerRadius}" HasPaddedDropShadow="True">

		<TStyle:InstancedWindowLayout.Title>
			<Terminus:IntenseStareType1 Style="{StaticResource Base:WindowLayout.TitleBar.TitleText}" UID="[Update notice] * Title" />
		</TStyle:InstancedWindowLayout.Title>

		<TStyle:InstancedWindowLayout.Navigation>
			<Button Click="Minimize" Style="{StaticResource Base:TitleBar.Button.Defaults.Minimize}" />
			<Button Click="FadeClose" Style="{StaticResource Base:TitleBar.Button.Defaults.Close}" />
		</TStyle:InstancedWindowLayout.Navigation>

		<TStyle:InstancedWindowLayout.Content>
			<Grid Background="{DynamicResource Theme:Common.DialogWindows.Background.Color}">

				<Terminus:IntenseStareType1 x:Name="CaptionBinder" UID="[Update notice] [!] [#] * Title (Window caption)" Visibility="Collapsed" />

				<Abstractions:DialogWindowContentPresenter>
					<Grid MaxWidth="480">
						<Grid.ColumnDefinitions>
							<ColumnDefinition MaxWidth="80" />
							<ColumnDefinition />
						</Grid.ColumnDefinitions>
						<Image x:Name="ZenaImage" VerticalAlignment="Top" Source="/UI/Limbus/Zena Cat/몰컴.png" />
						<StackPanel Grid.Column="1" Margin="15 0 0 0">
							<Terminus:IntenseStareType1 FontSize="17" LineHeight="20" TextAlignment="Center" UID="[Update notice] * Text" />
							<StackPanel Margin="0 10 0 0" HorizontalAlignment="Center" Orientation="Horizontal">
								<Button x:Name="OpenNewVersionLinkButton" Click="OpenNewVersionLinkButton_Click" Style="{StaticResource Theme:ControlStyles.ElongatedButton}">
									<Terminus:IntenseStareType1 Width="80" FontSize="20" RichText="OK" TextAlignment="Center" UID="[Update notice] * OK Button" />
								</Button>
								<Button Margin="5 0 0 0" Click="FadeClose" Style="{StaticResource Theme:ControlStyles.ElongatedButton}">
									<Terminus:IntenseStareType1 Width="80" FontSize="20" RichText="Cancel" TextAlignment="Center" UID="[Update notice] * Cancel Button" />
								</Button>
							</StackPanel>
						</StackPanel>
					</Grid>
				</Abstractions:DialogWindowContentPresenter>

			</Grid>
		</TStyle:InstancedWindowLayout.Content>

	</TStyle:InstancedWindowLayout>

</Abstractions:DialogWindowBase>