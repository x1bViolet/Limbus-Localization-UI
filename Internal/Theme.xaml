<ResourceDictionary
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:sys="clr-namespace:System;assembly=mscorlib">
	
	<!--#region Title Bar-->
	<SolidColorBrush x:Key="Theme:TitleBar.Icons" Color="#ADADAD" />
	<SolidColorBrush x:Key="Theme:TitleBar.TitlesForeground" Color="#473131" />
	<SolidColorBrush x:Key="Theme:TitleBar.Background.Color" Color="#101117" />
	<CornerRadius    x:Key="Theme:TitleBar.Buttons.CornerRadius">4</CornerRadius>
	<SolidColorBrush x:Key="Theme:TitleBar.Buttons.Highlighted" Color="#302829" />
	<SolidColorBrush x:Key="Theme:TitleBar.Buttons.Highlighted.ExitButton" Color="#A52C42" />
	<!--#endregion-->


	<!--#region Common-->
	<SolidColorBrush x:Key="Theme:Common.ContextMenus.Separator.Color" Color="#FFFFFF" />


	<sys:Boolean     x:Key="Theme:Common.WindowsDropShadow.Enabled">True</sys:Boolean>
	<Color           x:Key="Theme:Common.WindowsDropShadow.Color">#000000</Color>


	<SolidColorBrush x:Key="Theme:Common.MainWindow.Border.Color" Color="#3A3A3A" />
	<CornerRadius    x:Key="Theme:Common.MainWindow.Border.CornerRadius">4</CornerRadius>
	<SolidColorBrush x:Key="Theme:Common.MainWindow.Background.Color" Color="#0F0F0F" />
	<BitmapImage     x:Key="Theme:Common.MainWindow.Background.Image" UriSource="/UI/Empty image.png" />
	<SolidColorBrush x:Key="Theme:Common.MainWindow.Background.Image.Shadow" Color="#00000000" />

	<SolidColorBrush x:Key="Theme:Common.MainWindow.PreviewCreator.Background.Color" Color="#0F0F0F" />
	<BitmapImage     x:Key="Theme:Common.MainWindow.PreviewCreator.Background.Image" UriSource="/UI/Empty image.png" />
	<SolidColorBrush x:Key="Theme:Common.MainWindow.PreviewCreator.Background.Image.Shadow" Color="#00000000" />


	<SolidColorBrush x:Key="Theme:Common.DialogWindows.Border.Color" Color="#3A3A3A" />
	<CornerRadius    x:Key="Theme:Common.DialogWindows.Border.CornerRadius">4</CornerRadius>
	<SolidColorBrush x:Key="Theme:Common.DialogWindows.Background.Color" Color="#0F0F0F" />
	<BitmapImage     x:Key="Theme:Common.DialogWindows.Background.Image" UriSource="/UI/Empty image.png" />
	<SolidColorBrush x:Key="Theme:Common.DialogWindows.Background.Image.Shadow" Color="#00000000" />


	<SolidColorBrush x:Key="Theme:Common.SettingsWindow.Border.Color" Color="#3A3A3A" />
	<CornerRadius    x:Key="Theme:Common.SettingsWindow.Border.CornerRadius">4</CornerRadius>
	<SolidColorBrush x:Key="Theme:Common.SettingsWindow.Background.Color" Color="#191818" />
	<BitmapImage     x:Key="Theme:Common.SettingsWindow.Background.Image" UriSource="/UI/Empty image.png" />
	<SolidColorBrush x:Key="Theme:Common.SettingsWindow.Background.Image.Shadow" Color="#00000000" />
    <Color           x:Key="Theme:Common.SettingsWindow.SpecificSettings.CautionsColor">#FF4500</Color>


    <SolidColorBrush x:Key="Theme:Common.SkillsDisplayInfoManagerWindow.Border.Color" Color="#3A3A3A" />
    <CornerRadius    x:Key="Theme:Common.SkillsDisplayInfoManagerWindow.Border.CornerRadius">4</CornerRadius>
    <SolidColorBrush x:Key="Theme:Common.SkillsDisplayInfoManagerWindow.Background.Color" Color="#0F0F0F" />
    <BitmapImage     x:Key="Theme:Common.SkillsDisplayInfoManagerWindow.Background.Image" UriSource="/UI/Empty image.png" />
    <SolidColorBrush x:Key="Theme:Common.SkillsDisplayInfoManagerWindow.Background.Image.Shadow" Color="#00000000" />



	<SolidColorBrush x:Key="Theme:Common.RightMenu.NavigationPanel.Background" Color="#00000000" />
	<SolidColorBrush x:Key="Theme:Common.RightMenu.UptieButtons.Background" Color="#0E0907" />
	<SolidColorBrush x:Key="Theme:Common.RightMenu.CurrentObjectID.Foreground" Color="#DDD9D9" />
	<SolidColorBrush x:Key="Theme:Common.RightMenu.UptieTierText.Foreground" Color="#E6C5C5" />
	<!--#endregion-->


	<!--#region UI Text-->
	<SolidColorBrush x:Key="Theme:UIText.MainWindow.Foreground" Color="#D5CDCD" />
	<SolidColorBrush x:Key="Theme:UIText.MainWindow.Foreground.Tooltips" Color="#D5CDCD" />
	<SolidColorBrush x:Key="Theme:UIText.MainWindow.PreviewCreator.Foreground" Color="#D5CDCD" />
	<SolidColorBrush x:Key="Theme:UIText.MainWindow.PreviewCreator.Foreground.Tooltips" Color="#D5CDCD" />
	<SolidColorBrush x:Key="Theme:UIText.DialogWindows.Foreground" Color="#EEEEEE" />
	<SolidColorBrush x:Key="Theme:UIText.DialogWindows.Foreground.Tooltips" Color="#D5CDCD" />
	<SolidColorBrush x:Key="Theme:UIText.SettingsWindow.Foreground" Color="#D5CDCD" />
	<SolidColorBrush x:Key="Theme:UIText.SettingsWindow.Foreground.Comments" Color="#B2ABAB" />
	<SolidColorBrush x:Key="Theme:UIText.SettingsWindow.Foreground.Tooltips" Color="#D5CDCD" />
	<!--#endregion-->


	<!--#region UI Textfields-->
	<SolidColorBrush x:Key="Theme:UITextfields.Foreground" Color="#ABA193" />
	<SolidColorBrush x:Key="Theme:UITextfields.ShadowText.Foreground" Color="#514C46" />
	<SolidColorBrush x:Key="Theme:UITextfields.Background" Color="#181818" />

	<SolidColorBrush x:Key="Theme:UITextfields.Border" Color="#333333" />
	<Thickness       x:Key="Theme:UITextfields.Border.Thickness">1</Thickness>
	<CornerRadius    x:Key="Theme:UITextfields.Border.CornerRadius">1.5</CornerRadius>

	<SolidColorBrush x:Key="Theme:UITextfields.Caret" Color="#E9DBC6" />

	<!--#region Selection-->
	<SolidColorBrush x:Key="Theme:UITextfields.Selection.Foreground" Color="#ABA193" />
	<SolidColorBrush x:Key="Theme:UITextfields.Selection.Background" Color="#55B4B4B4" />

	<SolidColorBrush x:Key="Theme:UITextfields.Selection.Border" Color="#66D4D4D4" />
	<sys:Double      x:Key="Theme:UITextfields.Selection.Border.Thickness">1</sys:Double>
	<sys:Double      x:Key="Theme:UITextfields.Selection.Border.CornerRadius">0</sys:Double>
	<!--#endregion-->
	<!--#endregion-->


	<!--#region Json Text Editor-->
	<SolidColorBrush x:Key="Theme:JsonTextEditor.Foreground" Color="#ABA193" />
	<SolidColorBrush x:Key="Theme:JsonTextEditor.Background" Color="#191919" />
	
	<FontFamily      x:Key="Theme:JsonTextEditor.Font"></FontFamily>
	<FontWeight      x:Key="Theme:JsonTextEditor.FontWeight">Regular</FontWeight>
	<FontStretch     x:Key="Theme:JsonTextEditor.FontStretch">Normal</FontStretch>
	<sys:Double      x:Key="Theme:JsonTextEditor.FontSize">16.8</sys:Double>
	
	<SolidColorBrush x:Key="Theme:JsonTextEditor.Border" Color="#333333" />
	<Thickness       x:Key="Theme:JsonTextEditor.Border.Thickness">1</Thickness>
	<CornerRadius    x:Key="Theme:JsonTextEditor.Border.CornerRadius">1.5</CornerRadius>

	<SolidColorBrush x:Key="Theme:JsonTextEditor.Caret" Color="#E9DBC6" />
	
	<!--#region Selection-->
	<SolidColorBrush x:Key="Theme:JsonTextEditor.Selection.Foreground" Color="#ABA193" />
	<SolidColorBrush x:Key="Theme:JsonTextEditor.Selection.Background" Color="#55B4B4B4" />
	
	<SolidColorBrush x:Key="Theme:JsonTextEditor.Selection.Border" Color="#66D4D4D4" />
	<sys:Double      x:Key="Theme:JsonTextEditor.Selection.Border.Thickness">1</sys:Double>
	<sys:Double      x:Key="Theme:JsonTextEditor.Selection.Border.CornerRadius">0</sys:Double>
	<!--#endregion-->
	<!--#endregion-->
	
	
	<!--#region Unsaved changes-->
	<!--#region Main Editor-->
	<SolidColorBrush x:Key="Theme:UnsavedChanges.MainEditor.BlurredBackground">#8C090909</SolidColorBrush>
	<!--#endregion-->

	<!--#region Json Difference Viewer-->
	<SolidColorBrush x:Key="Theme:UnsavedChanges.PreviewCreator.BlurredBackground">#8C090909</SolidColorBrush>
	
	<FontFamily x:Key="Theme:UnsavedChanges.PreviewCreator.Diff.Font">Cascadia Code</FontFamily>
	<sys:Double x:Key="Theme:UnsavedChanges.PreviewCreator.Diff.FontSize">14</sys:Double>
	<FontWeight x:Key="Theme:UnsavedChanges.PreviewCreator.Diff.FontWeight">Regular</FontWeight>
	<FontStretch x:Key="Theme:UnsavedChanges.PreviewCreator.Diff.FontStretch">Normal</FontStretch>

	<SolidColorBrush x:Key="Theme:UnsavedChanges.PreviewCreator.Diff.Foreground">#D5CDCD</SolidColorBrush>
	<SolidColorBrush x:Key="Theme:UnsavedChanges.PreviewCreator.Diff.LineNumbers">#999393</SolidColorBrush>


	<SolidColorBrush x:Key="Theme:UnsavedChanges.PreviewCreator.Diff.OldValue.Foreground">#D5CDCD</SolidColorBrush>
	<SolidColorBrush x:Key="Theme:UnsavedChanges.PreviewCreator.Diff.OldValue.Background">#40D82020</SolidColorBrush>

	<SolidColorBrush x:Key="Theme:UnsavedChanges.PreviewCreator.Diff.NewValue.Foreground">#D5CDCD</SolidColorBrush>
	<SolidColorBrush x:Key="Theme:UnsavedChanges.PreviewCreator.Diff.NewValue.Background">#4060D820</SolidColorBrush>

	
	<SolidColorBrush x:Key="Theme:UnsavedChanges.PreviewCreator.Diff.ChangeTypeIcon">#808080</SolidColorBrush>
	<!--#endregion-->
	<!--#endregion-->


	<!--#region Square Buttons-->
	<SolidColorBrush x:Key="Theme:SquareButtons.DisabledButtonsShadowing" Color="#77000000" />
	<SolidColorBrush x:Key="Theme:SquareButtons.Icons" Color="#DEDEDE" />
	<SolidColorBrush x:Key="Theme:SquareButtons.ComboBox.DropDownArrow" Color="#DEDEDE" />
	<SolidColorBrush x:Key="Theme:SquareButtons.Background" Color="#181818" />
	<SolidColorBrush x:Key="Theme:SquareButtons.Background.Pressed" Color="#202020" />
	<SolidColorBrush x:Key="Theme:SquareButtons.Background.Highlighted" Color="#282828" />
	<SolidColorBrush x:Key="Theme:SquareButtons.Border" Color="#333333" />
	<Thickness       x:Key="Theme:SquareButtons.Border.Thickness">1</Thickness>
	<CornerRadius    x:Key="Theme:SquareButtons.Border.CornerRadius">1.5</CornerRadius>
	<!--#endregion-->


	<!--#region Elongated Buttons-->
	<SolidColorBrush x:Key="Theme:ElongatedButtons.DisabledButtonsShadowing" Color="#77000000" />
	<SolidColorBrush x:Key="Theme:ElongatedButtons.Background" Color="#181818" />
	<SolidColorBrush x:Key="Theme:ElongatedButtons.Background.Pressed" Color="#202020" />
	<SolidColorBrush x:Key="Theme:ElongatedButtons.Background.Highlighted" Color="#282828" />
	<SolidColorBrush x:Key="Theme:ElongatedButtons.Border" Color="#333333" />
	<Thickness       x:Key="Theme:ElongatedButtons.Border.Thickness">1</Thickness>
	<CornerRadius    x:Key="Theme:ElongatedButtons.Border.CornerRadius">1.5</CornerRadius>
	<!--#endregion-->


	<!--#region Scrollbars-->
	<SolidColorBrush x:Key="Theme:ScrollBars.Line" Color="#333333" />
	<sys:Double      x:Key="Theme:ScrollBars.Line.Thickness">2</sys:Double>


	<!--#region Up/Down Buttons-->
	<SolidColorBrush x:Key="Theme:ScrollBars.UpDownButtons.Icon" Color="#DEDEDE" />
	<SolidColorBrush x:Key="Theme:ScrollBars.UpDownButtons.Background" Color="#181818" />
	<SolidColorBrush x:Key="Theme:ScrollBars.UpDownButtons.Background.Pressed" Color="#141414" />
	<SolidColorBrush x:Key="Theme:ScrollBars.UpDownButtons.Background.Highlighted" Color="#282828" />
	<SolidColorBrush x:Key="Theme:ScrollBars.UpDownButtons.Border" Color="#333333" />
	<Thickness       x:Key="Theme:ScrollBars.UpDownButtons.Border.Thickness">1</Thickness>
	<CornerRadius    x:Key="Theme:ScrollBars.UpDownButtons.Border.CornerRadius">1.5</CornerRadius>
	<!--#endregion-->


	<!--#region Thumb-->
	<SolidColorBrush x:Key="Theme:ScrollBars.Thumb.Background" Color="#181818" />
	<SolidColorBrush x:Key="Theme:ScrollBars.Thumb.Background.Pressed" Color="#141414" />
	<SolidColorBrush x:Key="Theme:ScrollBars.Thumb.Background.Highlighted" Color="#181818" />
	<SolidColorBrush x:Key="Theme:ScrollBars.Thumb.Border" Color="#333333" />
	<Thickness       x:Key="Theme:ScrollBars.Thumb.Border.Thickness">1.7</Thickness>
	<CornerRadius    x:Key="Theme:ScrollBars.Thumb.Border.CornerRadius">1.5</CornerRadius>
	<!--#endregion-->
	<!--#endregion-->
	
	
	<!--#region Sliders-->
	<SolidColorBrush x:Key="Theme:Slider.Thumb.Default.Background" Color="#B8B3B1" />
	<SolidColorBrush x:Key="Theme:Slider.Thumb.Default.Border" Color="#888381" />

	<SolidColorBrush x:Key="Theme:Slider.Thumb.Highlighted.Background" Color="#CDC7C5" />
	<SolidColorBrush x:Key="Theme:Slider.Thumb.Highlighted.Border" Color="#888381" />

	<SolidColorBrush x:Key="Theme:Slider.Thumb.Pressed.Background" Color="#999593" />
	<SolidColorBrush x:Key="Theme:Slider.Thumb.Pressed.Border" Color="#888381" />

	
	<CornerRadius    x:Key="Theme:Slider.Thumb.CornerRadius">1</CornerRadius>
	<Thickness       x:Key="Theme:Slider.Thumb.BorderThickness">1.7</Thickness>
	
	<sys:Double      x:Key="Theme:Slider.Thumb.Width">11</sys:Double>
	<sys:Double      x:Key="Theme:Slider.Thumb.Height">18</sys:Double>
	
	<sys:Double      x:Key="Theme:Slider.Thumb.Scale">1</sys:Double>

	
	<sys:Double      x:Key="Theme:Slider.Line.Height">3.5</sys:Double>
	
	<Thickness       x:Key="Theme:Slider.Line.BorderThickness">1</Thickness>
	<CornerRadius    x:Key="Theme:Slider.Line.CornerRadius">0</CornerRadius>

	<SolidColorBrush x:Key="Theme:Slider.Line.Background" Color="#B0ADAC" />
	<SolidColorBrush x:Key="Theme:Slider.Line.Border" Color="#A6A09E" />
	<!--#endregion-->


	<!--#region Other Border-like things-->
	<SolidColorBrush x:Key="Theme:OtherBorderLikeThings.Background" Color="#181818" />
	<SolidColorBrush x:Key="Theme:OtherBorderLikeThings.Border" Color="#333333" />
	<Thickness       x:Key="Theme:OtherBorderLikeThings.Border.Thickness">1</Thickness>
	<CornerRadius    x:Key="Theme:OtherBorderLikeThings.Border.CornerRadius">1.5</CornerRadius>
	<!--#endregion-->
	
</ResourceDictionary>